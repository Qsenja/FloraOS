#!/usr/bin/env bash
# fau — FloraOS's package manager.
# Package format: <name>-<version>.fau.tar.zst, containing:
#   pkginfo   key=value metadata (name, version, description, depends, bin)
#   files/    payload
#
# Two install modes:
#   install / remove / list   — system packages, merged into FAU_ROOT (/usr, /etc, ...)
#   app-install / app-remove / app-list — user apps, each isolated under
#     FAU_APPS_DIR/<name>/ with its own config/cache/data/logs, never touching
#     the system root. See "bin" in pkginfo: comma-separated relative paths
#     under files/ that should get a PATH-visible wrapper.
set -euo pipefail

FAU_ROOT="${FAU_ROOT:-/}"
FAU_REPO_DIR="${FAU_REPO_DIR:-/etc/fau/repo}"
FAU_STATE_DIR="${FAU_ROOT%/}/var/lib/fau"
FAU_CACHE_DIR="${FAU_ROOT%/}/var/cache/fau/pkg"
FAU_SYSTEM_JSON="${FAU_STATE_DIR}/system.json"

FAU_APPS_DIR="${FAU_APPS_DIR:-$HOME/apps}"
FAU_APPS_BIN_DIR="${FAU_APPS_DIR}/.bin"
FAU_APPS_JSON="${FAU_APPS_DIR}/.fau-apps.json"

die() { echo "fau: error: $*" >&2; exit 1; }
log() { echo "fau: $*" >&2; }

usage() {
	cat <<'EOF'
usage: fau <command> [args]

commands:
  install <pkg> [pkg ...]   install system package(s) into FAU_ROOT, with dependencies
  remove <pkg> [pkg ...]    remove system package(s) (files only, no dependency check)
  list                      list installed system packages and versions
  export [file]             write system.json to file (default: stdout)
  apply <file>              install the exact system package set recorded in file

  app-install <pkg> [...]  install user app(s) into FAU_APPS_DIR/<name>/, isolated
  app-remove <pkg> [...]    remove user app(s) and their PATH wrappers
  app-list                 list installed user apps and versions

  repo-add <archive>        add a built .fau.tar.zst to the local repo and index it
  repo-index                rebuild repo.json from the archives present in the repo dir

environment:
  FAU_ROOT        target root for system packages (default: /)
  FAU_REPO_DIR    directory holding .fau.tar.zst archives + repo.json (default: /etc/fau/repo)
  FAU_APPS_DIR    directory for isolated user apps (default: $HOME/apps)
EOF
}

json_escape() {
	# minimal JSON string escaping for the fields we actually emit (no control chars expected)
	local s=$1
	s=${s//\\/\\\\}
	s=${s//\"/\\\"}
	printf '%s' "$s"
}

pkginfo_field() {
	# pkginfo_field <pkginfo-file> <key>
	grep "^$2=" "$1" 2>/dev/null | head -n1 | cut -d'=' -f2- || true
}

state_init() {
	mkdir -p "$FAU_STATE_DIR" "$FAU_CACHE_DIR"
	[ -f "$FAU_SYSTEM_JSON" ] || printf '{"packages":{}}\n' > "$FAU_SYSTEM_JSON"
}

apps_state_init() {
	mkdir -p "$FAU_APPS_DIR" "$FAU_APPS_BIN_DIR"
	[ -f "$FAU_APPS_JSON" ] || printf '{"packages":{}}\n' > "$FAU_APPS_JSON"
}

# --- manifest (system.json / apps.json) read/write --------------------------
# Flat schema only: {"packages":{"name":{"version":"x"},...}}. Hand-rolled
# parsing is fine at this scale; revisit if the schema grows. Both
# system.json and the per-user apps.json share this format and these helpers,
# parameterized by which file to operate on.

json_get_version() {
	# json_get_version <file> <name>  -> prints version or nothing
	local file=$1 name=$2
	grep -o "\"$name\"[[:space:]]*:[[:space:]]*{[[:space:]]*\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$file" 2>/dev/null \
		| sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/' || true
}

json_list_names() {
	local file=$1
	grep -oE '"[^"]+"[[:space:]]*:[[:space:]]*\{[[:space:]]*"version"' "$file" 2>/dev/null \
		| sed -E 's/^"([^"]+)".*/\1/' || true
}

json_set() {
	# json_set <file> <name> <version>  — add or update an entry
	local file=$1 name=$2 version=$3
	local tmp; tmp=$(mktemp)
	{
		echo '{"packages":{'
		local first=1
		for n in $(json_list_names "$file"); do
			[ "$n" = "$name" ] && continue
			local v; v=$(json_get_version "$file" "$n")
			[ $first -eq 1 ] || echo ','
			first=0
			printf '"%s":{"version":"%s"}' "$(json_escape "$n")" "$(json_escape "$v")"
		done
		[ $first -eq 1 ] || echo ','
		printf '"%s":{"version":"%s"}' "$(json_escape "$name")" "$(json_escape "$version")"
		echo
		echo '}}'
	} > "$tmp"
	mv "$tmp" "$file"
}

json_unset() {
	local file=$1 name=$2
	local tmp; tmp=$(mktemp)
	{
		echo '{"packages":{'
		local first=1
		for n in $(json_list_names "$file"); do
			[ "$n" = "$name" ] && continue
			local v; v=$(json_get_version "$file" "$n")
			[ $first -eq 1 ] || echo ','
			first=0
			printf '"%s":{"version":"%s"}' "$(json_escape "$n")" "$(json_escape "$v")"
		done
		echo
		echo '}}'
	} > "$tmp"
	mv "$tmp" "$file"
}

system_get_version() { json_get_version "$FAU_SYSTEM_JSON" "$1"; }
system_list_names() { json_list_names "$FAU_SYSTEM_JSON"; }
system_set() { json_set "$FAU_SYSTEM_JSON" "$1" "$2"; }
system_unset() { json_unset "$FAU_SYSTEM_JSON" "$1"; }

# --- repo --------------------------------------------------------------------

repo_json() { echo "${FAU_REPO_DIR%/}/repo.json"; }

repo_index() {
	local repo; repo=$(repo_json)
	mkdir -p "$FAU_REPO_DIR"
	local tmp; tmp=$(mktemp)
	{
		echo '{"packages":{'
		local first=1
		shopt -s nullglob
		for archive in "$FAU_REPO_DIR"/*.fau.tar.zst; do
			local work; work=$(mktemp -d)
			tar -I zstd -xf "$archive" -C "$work" pkginfo
			local name version sha
			name=$(pkginfo_field "$work/pkginfo" name)
			version=$(pkginfo_field "$work/pkginfo" version)
			sha=$(sha256sum "$archive" | cut -d' ' -f1)
			rm -rf "$work"
			[ $first -eq 1 ] || echo ','
			first=0
			printf '"%s":{"version":"%s","file":"%s","sha256":"%s"}' \
				"$(json_escape "$name")" "$(json_escape "$version")" \
				"$(json_escape "$(basename "$archive")")" "$sha"
		done
		echo
		echo '}}'
	} > "$tmp"
	mv "$tmp" "$repo"
	log "indexed $(basename "$FAU_REPO_DIR")"
}

repo_lookup_file() {
	# repo_lookup_file <name> -> prints archive filename, or nothing if
	# there's no repo index yet or the name isn't in it (not an error here --
	# callers that need a system package to exist check for an empty result
	# themselves; app_install_one falls back to pacman on an empty result)
	local name=$1 repo; repo=$(repo_json)
	[ -f "$repo" ] || return 0
	awk -v n="\"$name\"" '
		index($0, n":{") { in_pkg=1 }
		in_pkg && match($0, /"file":"[^"]*"/) {
			s = substr($0, RSTART, RLENGTH)
			sub(/"file":"/, "", s); sub(/"$/, "", s)
			print s; exit
		}
	' "$repo"
}

repo_lookup_depends() {
	local archive=$1
	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work" pkginfo
	pkginfo_field "$work/pkginfo" depends
	rm -rf "$work"
}

repo_add() {
	local archive=$1
	[ -f "$archive" ] || die "no such archive: $archive"
	mkdir -p "$FAU_REPO_DIR"
	cp "$archive" "$FAU_REPO_DIR/"
	repo_index
}

# --- install/remove ----------------------------------------------------------

install_one() {
	local name=$1
	local file; file=$(repo_lookup_file "$name")
	if [ -z "$file" ]; then
		if command -v pacman >/dev/null 2>&1; then
			install_one_pacman "$name"
			return
		fi
		die "package not found in repo: $name (and pacman isn't available to fall back to)"
	fi

	local existing; existing=$(system_get_version "$name")
	local archive="${FAU_REPO_DIR%/}/${file}"

	local depends; depends=$(repo_lookup_depends "$archive")
	if [ -n "${depends:-}" ]; then
		# tr, not `local IFS=','`: IFS is function-scoped, not block-scoped,
		# so it would still be ',' for every command below this loop within
		# this same call (notably system_set's own word-splitting) -- that's
		# exactly what corrupted system.json before this fix.
		for dep in $(printf '%s' "$depends" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			[ -n "$(system_get_version "$dep")" ] || install_one "$dep"
		done
	fi

	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work"
	local version; version=$(pkginfo_field "$work/pkginfo" version)
	mkdir -p "$FAU_ROOT"
	# rsync -a alone replaces a destination symlink-to-directory (e.g. the
	# merged-/usr bin/sbin/lib/lib64 symlinks) with a real directory;
	# --keep-dirlinks (-K) keeps the symlink and merges into its target
	# instead, which is what installing multiple packages into one merged
	# root requires. Plain cp -a refuses the merge outright ("cannot
	# overwrite non-directory X with directory Y").
	rsync -aK "$work/files/" "$FAU_ROOT/"
	rm -rf "$work"

	system_set "$name" "$version"
	if [ -n "$existing" ]; then
		log "upgraded $name $existing -> $version"
	else
		log "installed $name $version"
	fi
}

cmd_install() {
	[ $# -ge 1 ] || die "install requires at least one package name"
	state_init
	for name in "$@"; do install_one "$name"; done
}

cmd_remove() {
	[ $# -ge 1 ] || die "remove requires at least one package name"
	state_init
	for name in "$@"; do
		[ -n "$(system_get_version "$name")" ] || { log "$name is not installed, skipping"; continue; }
		system_unset "$name"
		log "removed $name from system.json (files left in place — fau does not track individual files yet)"
	done
}

cmd_list() {
	state_init
	for n in $(system_list_names); do
		printf '%s %s\n' "$n" "$(system_get_version "$n")"
	done
}

cmd_export() {
	state_init
	if [ $# -ge 1 ]; then cp "$FAU_SYSTEM_JSON" "$1"; else cat "$FAU_SYSTEM_JSON"; fi
}

cmd_apply() {
	[ $# -eq 1 ] || die "apply requires exactly one manifest file"
	local manifest=$1
	[ -f "$manifest" ] || die "no such file: $manifest"
	state_init
	local names
	names=$(grep -oE '"[^"]+"[[:space:]]*:[[:space:]]*\{[[:space:]]*"version"' "$manifest" \
		| sed -E 's/^"([^"]+)".*/\1/')
	for n in $names; do install_one "$n"; done
}

# --- app-install/app-remove/app-list -----------------------------------------
# Each app lives entirely under FAU_APPS_DIR/<name>/: its own files, plus
# config/cache/data/logs subdirs. Wrapper scripts in FAU_APPS_BIN_DIR (put
# that on PATH) set HOME/XDG_*_HOME to redirect the app into its own
# directory before exec'ing the real binary -- works for any app that
# follows the XDG Base Directory spec (most modern Linux software does).
# Apps that hardcode absolute paths won't cooperate; that's a known limit,
# not a bug.

app_wrapper_write() {
	# app_wrapper_write <name> <app-dir> <relbin>
	local name=$1 app_dir=$2 relbin=$3
	local cmd_name; cmd_name=$(basename "$relbin")
	local wrapper="$FAU_APPS_BIN_DIR/$cmd_name"
	local app_libdir="$app_dir/usr/lib:$app_dir/lib"
	cat > "$wrapper" <<-EOF
	#!/bin/sh
	export HOME="$app_dir"
	export XDG_CONFIG_HOME="$app_dir/config"
	export XDG_CACHE_HOME="$app_dir/cache"
	export XDG_DATA_HOME="$app_dir/data"
	export XDG_STATE_HOME="$app_dir/logs"
	export LD_LIBRARY_PATH="$app_libdir\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}"
	export PATH="$app_dir/usr/bin:$app_dir/bin\${PATH:+:\$PATH}"
	exec "$app_dir/$relbin" "\$@"
	EOF
	chmod 755 "$wrapper"
}

app_install_one() {
	local name=$1
	local file; file=$(repo_lookup_file "$name")
	if [ -z "$file" ]; then
		if command -v pacman >/dev/null 2>&1; then
			app_install_one_pacman "$name"
			return
		fi
		die "package not found in repo: $name (and pacman isn't available to fall back to)"
	fi

	local existing; existing=$(json_get_version "$FAU_APPS_JSON" "$name")
	local archive="${FAU_REPO_DIR%/}/${file}"

	local depends; depends=$(repo_lookup_depends "$archive")
	if [ -n "${depends:-}" ]; then
		for dep in $(printf '%s' "$depends" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			[ -n "$(json_get_version "$FAU_APPS_JSON" "$dep")" ] || app_install_one "$dep"
		done
	fi

	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work"
	local version bin; version=$(pkginfo_field "$work/pkginfo" version)
	bin=$(pkginfo_field "$work/pkginfo" bin)

	local app_dir="${FAU_APPS_DIR%/}/${name}"
	rm -rf "$app_dir"
	mkdir -p "$app_dir" "$app_dir/config" "$app_dir/cache" "$app_dir/data" "$app_dir/logs"
	cp -a "$work/files/." "$app_dir"
	cp "$work/pkginfo" "$app_dir/.pkginfo"
	rm -rf "$work"

	if [ -z "${bin:-}" ] && [ -d "$app_dir/bin" ]; then
		bin=$(find "$app_dir/bin" -maxdepth 1 -type f -printf 'bin/%f,' 2>/dev/null)
	fi
	if [ -n "${bin:-}" ]; then
		for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
			relbin=$(echo "$relbin" | xargs)
			[ -z "$relbin" ] && continue
			app_wrapper_write "$name" "$app_dir" "$relbin"
		done
	fi

	json_set "$FAU_APPS_JSON" "$name" "$version"
	if [ -n "$existing" ]; then
		log "upgraded app $name $existing -> $version"
	else
		log "installed app $name $version into $app_dir"
	fi
	case ":$PATH:" in
		*":$FAU_APPS_BIN_DIR:"*) ;;
		*) log "note: $FAU_APPS_BIN_DIR is not on your PATH yet — add it to use $name's commands directly" ;;
	esac
}

# --- pacman-backed fallback ---------------------------------------------------
# Until FloraOS has its own curated app catalog, app-install falls back to
# pulling from this build host's pacman/Artix repos when a package isn't in
# the local fau repo. This only fetches (no root, no installing onto the
# real system): a scratch pacman db with an *empty* local-package state is
# used so `pacman -Sp` resolves the FULL dependency closure regardless of
# what's already installed on this host, not just what's "missing" here.
# Real caveat: pacman binaries are built against Artix's glibc -- this only
# works cleanly as long as that stays ABI-compatible with FloraOS's own
# from-scratch glibc (currently identical versions by coincidence, not by
# any guarantee). GUI apps also won't have a display server to draw on yet
# (see ARCHITECTURE.md) -- this gets you the files, not a running X11.

pacman_scratch_db() {
	local db_dir="${FAU_APPS_DIR%/}/.pacman-db"
	if [ ! -d "$db_dir/sync" ] || [ -z "$(ls -A "$db_dir/sync" 2>/dev/null)" ]; then
		rm -rf "$db_dir"
		mkdir -p "$db_dir/sync" "$db_dir/local"
		cp /var/lib/pacman/sync/*.db "$db_dir/sync/" 2>/dev/null \
			|| die "couldn't read /var/lib/pacman/sync -- is pacman's sync db populated? (pacman -Sy)"
	fi
	echo "$db_dir"
}

pacman_desc_field() {
	# pacman_desc_field <db-dir> <repo> <pkg-dirname> <KEY> -> prints value
	local db_dir=$1 repo=$2 pkgdir=$3 key=$4
	local work; work=$(mktemp -d)
	tar -xzf "$db_dir/sync/${repo}.db" -C "$work" "$pkgdir/desc" 2>/dev/null
	awk -v k="%${key}%" 'f{print; f=0} $0==k{f=1}' "$work/$pkgdir/desc" 2>/dev/null
	rm -rf "$work"
}

pacman_pkgdir_for() {
	# pacman_pkgdir_for <db-dir> <repo> <name> -> the "name-version" dir inside repo.db
	local db_dir=$1 repo=$2 name=$3
	local work; work=$(mktemp -d)
	tar -xzf "$db_dir/sync/${repo}.db" -C "$work" 2>/dev/null
	find "$work" -maxdepth 1 -type d -name "${name}-*" -printf '%f\n' | while read -r d; do
		[ "$(awk '/%NAME%/{getline;print;exit}' "$work/$d/desc")" = "$name" ] && echo "$d" && break
	done
	rm -rf "$work"
}

pacman_mirror_url() {
	# pacman_mirror_url <repo> <filename> -> first configured mirror's URL
	local repo=$1 filename=$2
	local tmpl; tmpl=$(grep -m1 '^Server' /etc/pacman.d/mirrorlist | sed 's/^Server[[:space:]]*=[[:space:]]*//')
	[ -n "$tmpl" ] || die "no Server= line found in /etc/pacman.d/mirrorlist"
	local arch; arch=$(uname -m)
	tmpl=${tmpl//\$repo/$repo}
	tmpl=${tmpl//\$arch/$arch}
	echo "$tmpl/$filename"
}

install_one_pacman() {
	# System-side counterpart to app_install_one_pacman: merges into
	# FAU_ROOT (rsync -aK, same as install_one's own merge) and records into
	# system.json, instead of isolating into FAU_APPS_DIR. Used for base
	# packages fetched straight from this build host's pacman/Artix repos
	# rather than compiled from source (e.g. fastfetch during rootfs build).
	local name=$1
	local db_dir; db_dir=$(pacman_scratch_db)

	local resolved; resolved=$(pacman -Sp --dbpath "$db_dir" --print-format '%n %r' "$name" 2>&1) \
		|| die "pacman couldn't resolve '$name': $resolved"

	mkdir -p "$FAU_ROOT"
	local fetch_dir; fetch_dir=$(mktemp -d)
	local version=""

	while read -r pkgname repo; do
		[ -n "$pkgname" ] || continue
		local pkgdir; pkgdir=$(pacman_pkgdir_for "$db_dir" "$repo" "$pkgname")
		[ -n "$pkgdir" ] || die "couldn't find $pkgname in repo $repo's sync db"
		local filename sha256
		filename=$(pacman_desc_field "$db_dir" "$repo" "$pkgdir" FILENAME)
		sha256=$(pacman_desc_field "$db_dir" "$repo" "$pkgdir" SHA256SUM)
		[ -n "$filename" ] && [ -n "$sha256" ] || die "missing metadata for $pkgname in sync db"

		local dest="$fetch_dir/$filename"
		if [ -r "/var/cache/pacman/pkg/$filename" ]; then
			cp "/var/cache/pacman/pkg/$filename" "$dest"
		else
			local url; url=$(pacman_mirror_url "$repo" "$filename")
			curl -fsSL -o "$dest" "$url" || die "failed to fetch $pkgname from $url"
		fi
		local actual; actual=$(sha256sum "$dest" | cut -d' ' -f1)
		[ "$actual" = "$sha256" ] || die "checksum mismatch for $pkgname: expected $sha256, got $actual"

		local extract_dir; extract_dir=$(mktemp -d)
		tar --zstd -xf "$dest" -C "$extract_dir"
		# Some packages (dbus's daemon-launch-helper, for one) ship
		# intentionally unreadable setuid-root helpers as a hardening
		# measure -- meaningless in this unprivileged, non-system-installed
		# copy, but it breaks the merge step below since we can't even read
		# what we just extracted. u+rX ensures we always can.
		chmod -R u+rX "$extract_dir"
		rm -f "$extract_dir/.PKGINFO" "$extract_dir/.BUILDINFO" "$extract_dir/.MTREE" "$extract_dir/.INSTALL"
		[ "$pkgname" = "$name" ] && version=$(pacman_desc_field "$db_dir" "$repo" "$pkgdir" VERSION)
		rsync -aK "$extract_dir/" "$FAU_ROOT/"
		rm -rf "$extract_dir"
	done <<< "$resolved"
	rm -rf "$fetch_dir"

	system_set "$name" "${version:-unknown (via pacman)}"
	log "installed $name ${version:-(via pacman)} into $FAU_ROOT"
}

app_install_one_pacman() {
	local name=$1
	local db_dir; db_dir=$(pacman_scratch_db)

	local resolved; resolved=$(pacman -Sp --dbpath "$db_dir" --print-format '%n %r' "$name" 2>&1) \
		|| die "pacman couldn't resolve '$name': $resolved"

	local app_dir="${FAU_APPS_DIR%/}/${name}"
	rm -rf "$app_dir"
	mkdir -p "$app_dir" "$app_dir/config" "$app_dir/cache" "$app_dir/data" "$app_dir/logs"
	local fetch_dir; fetch_dir=$(mktemp -d)
	local target_files version=""

	while read -r pkgname repo; do
		[ -n "$pkgname" ] || continue
		local pkgdir; pkgdir=$(pacman_pkgdir_for "$db_dir" "$repo" "$pkgname")
		[ -n "$pkgdir" ] || die "couldn't find $pkgname in repo $repo's sync db"
		local filename sha256
		filename=$(pacman_desc_field "$db_dir" "$repo" "$pkgdir" FILENAME)
		sha256=$(pacman_desc_field "$db_dir" "$repo" "$pkgdir" SHA256SUM)
		[ -n "$filename" ] && [ -n "$sha256" ] || die "missing metadata for $pkgname in sync db"

		# Resolved directly, not via another `pacman -Sp <pkgname>` call --
		# that re-resolves *that* package's own sub-dependencies too and can
		# print several lines, making "the first line" ambiguous (caught by
		# the checksum check below the hard way once already).
		local dest="$fetch_dir/$filename"
		if [ -r "/var/cache/pacman/pkg/$filename" ]; then
			cp "/var/cache/pacman/pkg/$filename" "$dest"
		else
			local url; url=$(pacman_mirror_url "$repo" "$filename")
			curl -fsSL -o "$dest" "$url" || die "failed to fetch $pkgname from $url"
		fi
		local actual; actual=$(sha256sum "$dest" | cut -d' ' -f1)
		[ "$actual" = "$sha256" ] || die "checksum mismatch for $pkgname: expected $sha256, got $actual"

		local extract_dir; extract_dir=$(mktemp -d)
		tar --zstd -xf "$dest" -C "$extract_dir"
		# Some packages (dbus's daemon-launch-helper, for one) ship
		# intentionally unreadable setuid-root helpers as a hardening
		# measure -- meaningless in this unprivileged, non-system-installed
		# copy, but it breaks the merge step below since we can't even read
		# what we just extracted. u+rX ensures we always can.
		chmod -R u+rX "$extract_dir"
		rm -f "$extract_dir/.PKGINFO" "$extract_dir/.BUILDINFO" "$extract_dir/.MTREE" "$extract_dir/.INSTALL"
		if [ "$pkgname" = "$name" ]; then
			version=$(pacman_desc_field "$db_dir" "$repo" "$pkgdir" VERSION)
			target_files=$(cd "$extract_dir" && find usr/bin bin -maxdepth 1 -type f 2>/dev/null; true)
		fi
		cp -a "$extract_dir/." "$app_dir"
		rm -rf "$extract_dir"
	done <<< "$resolved"
	rm -rf "$fetch_dir"

	for relbin in $target_files; do
		app_wrapper_write "$name" "$app_dir" "$relbin"
	done

	json_set "$FAU_APPS_JSON" "$name" "${version:-unknown (via pacman)}"
	log "installed app $name (via pacman) into $app_dir"
	[ -n "$target_files" ] || log "note: couldn't find any usr/bin or bin entrypoint owned by $pkgname to wrap"
	case ":$PATH:" in
		*":$FAU_APPS_BIN_DIR:"*) ;;
		*) log "note: $FAU_APPS_BIN_DIR is not on your PATH yet — add it to use $name's commands directly" ;;
	esac
}

cmd_app_install() {
	[ $# -ge 1 ] || die "app-install requires at least one package name"
	apps_state_init
	for name in "$@"; do app_install_one "$name"; done
}

cmd_app_remove() {
	[ $# -ge 1 ] || die "app-remove requires at least one package name"
	apps_state_init
	for name in "$@"; do
		[ -n "$(json_get_version "$FAU_APPS_JSON" "$name")" ] || { log "app $name is not installed, skipping"; continue; }
		local app_dir="${FAU_APPS_DIR%/}/${name}"
		local bin; bin=$([ -f "$app_dir/.pkginfo" ] && pkginfo_field "$app_dir/.pkginfo" bin || true)
		if [ -n "${bin:-}" ]; then
			for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
				relbin=$(echo "$relbin" | xargs)
				[ -z "$relbin" ] && continue
				rm -f "$FAU_APPS_BIN_DIR/$(basename "$relbin")"
			done
		fi
		rm -rf "$app_dir"
		json_unset "$FAU_APPS_JSON" "$name"
		log "removed app $name (including its config/cache/data/logs)"
	done
}

cmd_app_list() {
	apps_state_init
	for n in $(json_list_names "$FAU_APPS_JSON"); do
		printf '%s %s\n' "$n" "$(json_get_version "$FAU_APPS_JSON" "$n")"
	done
}

main() {
	[ $# -ge 1 ] || { usage; exit 1; }
	local cmd=$1; shift
	case "$cmd" in
		install) cmd_install "$@" ;;
		remove) cmd_remove "$@" ;;
		list) cmd_list "$@" ;;
		export) cmd_export "$@" ;;
		apply) cmd_apply "$@" ;;
		app-install) cmd_app_install "$@" ;;
		app-remove) cmd_app_remove "$@" ;;
		app-list) cmd_app_list "$@" ;;
		repo-add) repo_add "$@" ;;
		repo-index) repo_index "$@" ;;
		-h|--help|help) usage ;;
		*) die "unknown command: $cmd (see --help)" ;;
	esac
}

main "$@"
