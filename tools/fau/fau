#!/usr/bin/env bash
# fau — FloraOS's system manager. This file is deliberately just the
# dispatcher: it owns the help/usage text (a coherent, single place to
# discover every command fau has, same job `git help` does for git's own
# many `git-<command>` binaries) and routes each command to the real tool
# that implements it -- it does not itself install a package, take a
# backup, or touch a service. Package install/remove, `fau backup`'s
# full-root snapshot/restore, and friendlier front ends over OpenRC/
# floraseat/florauser are what exist today; the intent is for fau to keep
# growing into managing the rest of the running system, not stay scoped to
# packages alone -- each new area of the system gets its own fau-<name>
# tool alongside these, not more logic bolted onto this file.
#
# Real implementations, one executable per area, in this same directory:
#   fau-bootstrap   build-time only: merges packages straight into FAU_ROOT
#   fau-install     user-facing: install/remove/list isolated apps
#   fau-build       builds a package from source on this system, on demand
#   fau-repo        fau's own local package repo (repo-add/repo-index)
#   fau-export      export/import (system.json + app configs bundle)
#   fau-backup      full-root btrfs snapshot/restore
#   fau-service     front end over OpenRC (rc-update/rc-service)
#   fau-seat        front end over floraseat's VT-bound switching
#   fau-user        front end over florauser (useradd/passwd/rename/...)
# Shared code (die/log/env-var defaults, system.json/apps.json read-write,
# the local repo, the Arch/Artix alpm fallback) lives in lib/*.sh, sourced
# by whichever of the above actually need it -- not by this dispatcher,
# which needs none of it.
#
# Every fau-<name> tool above is fully runnable on its own (`fau-backup
# backup-list` works exactly like `fau backup-list`) -- this script adds
# nothing but the unified `fau <command>` entry point and the help text.
set -euo pipefail

# readlink -f before dirname, not just dirname "${BASH_SOURCE[0]}" -- this
# file is staged at /usr/lib/fau/fau with /usr/bin/fau a symlink to it
# (build-rootfs.sh), and bash's own BASH_SOURCE reports the path *as
# invoked*, not the symlink's real target: plain dirname on that gives
# "/usr/bin", where none of this directory's sibling fau-*/lib/*.sh
# actually live. Found on a real boot test: `florainstall` (which execs
# `fau` by bare name, resolved via PATH to the /usr/bin symlink) failed
# with "/usr/bin/lib/common.sh: No such file or directory" before this was
# fixed. Every fau-* tool below resolves its own SELF_DIR the identical
# way, on the same reasoning -- none of them are symlinked today, but there's
# no reason a future one couldn't be, and the fix costs nothing when it isn't.
SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"

# usage() is the short, always-shown overview -- topics (see usage_topic)
# hold the actual per-command detail, so `fau` with no args or a bad
# invocation doesn't dump the entire, ever-growing command list every time.
# `fau help <topic>` / `fau help all` unpack the rest.
usage() {
	cat <<'EOF'
usage: fau <command> [args]
       fau help [topic]        this command's own commands, in full

topics: install, build, repo, export, backup, service, seat, user, bootstrap
        (or `fau help all` for every topic at once)

environment:
  FAU_ROOT        target root for bootstrap package(s) (default: /)
  FAU_REPO_DIR    directory holding .fau.tar.zst archives + repo.json (default: /etc/fau/repo)
  FAU_APPS_DIR    directory for isolated user apps (default: $HOME/apps)
  FAU_RECIPES_DIR directory of `fau build` recipes (default: /usr/lib/fau/recipes)
EOF
}

usage_topic() {
	local topic=$1
	case "$topic" in
		install|pkg|package|packages|packagemanager)
			cat <<'EOF'
install <pkg> [pkg ...]   install package(s) into FAU_APPS_DIR/<name>/, isolated
remove <pkg> [pkg ...]    remove package(s) and their PATH wrappers
list                      list installed packages and versions
EOF
			;;
		build)
			cat <<'EOF'
build <name>              build a package from source on this system, on demand,
                            from a recipe shipped at FAU_RECIPES_DIR/<name>.sh --
                            fetches whatever build-only tools that recipe needs
                            (a compiler, meson, ninja, ...) into a throwaway
                            sandbox, builds, installs into FAU_APPS_DIR/<name>/
                            like 'fau install' does, then wipes the sandbox --
                            this system never keeps a compiler around just
                            because it built one thing once. Heavier than a
                            normal install (can take minutes); 'fau install'
                            only ever hints at this, never falls back to it
                            automatically. 'fau remove <name>' works on a built
                            package exactly like any other installed app.
build-list                 list every recipe available at FAU_RECIPES_DIR
EOF
			;;
		repo)
			cat <<'EOF'
repo-add <archive>        add a built .fau.tar.zst to the local repo and index it
repo-index                rebuild repo.json from the archives present in the repo dir
EOF
			;;
		export|import)
			cat <<'EOF'
export [file]             bundle every installed app's config/ files plus a
                            full system.json (base packages + apps + config
                            file list) into file (default: system.flora)
import [file]             reinstall any missing app named in file's manifest,
                            then restore every config file it lists back into
                            place under FAU_APPS_DIR (default: system.flora)
EOF
			;;
		backup)
			cat <<'EOF'
backup <name>             snapshot / (read-only, btrfs) under @snapshots/<name>
                            and add a GRUB menu entry for it -- real disk
                            installs only (see florainstall)
backup-list               list existing backups, newest first
backup-remove <name>      delete a backup and its GRUB menu entry
backup-restore <name>     promote a backup to be the new / (the current root
                            is kept, renamed @pre-restore-<name>-<timestamp>);
                            reboot afterward to actually boot into it. Not
                            atomic -- a crash mid-restore is a real risk (see
                            backup-repair below and docs/TODO.md)
backup-repair <name>      complete an interrupted backup-restore <name> after
                            a crash left @ missing. Boot the "FloraOS
                            (backup: <name>)" GRUB entry first (it still
                            works -- only the default entry is broken), then
                            run this from there
EOF
			;;
		service)
			cat <<'EOF'
service-list              list OpenRC services: state (started/stopped/
                            failed/inactive) and enabled runlevel(s)
service-status <name>     state and enabled runlevel(s) for one service
service-enable <name> [runlevel]   enable at boot (default runlevel: default)
service-disable <name> [runlevel]  disable (default runlevel: default)
service-start <name>      start now
service-stop <name>       stop now
service-restart <name>    restart now
EOF
			;;
		seat|vt|floraseat)
			cat <<'EOF'
seat-status               currently active VT and floraseat's own recent
                            activate/disable log lines (/var/log/floraseat.log)
seat-switch <vt-number>    switch the active VT (chvt) -- floraseat reacts
                            automatically (VT-bound: disables whatever session
                            is on the outgoing VT, enables whatever claims the
                            incoming one), same as a physical Ctrl+Alt+Fn
EOF
			;;
		user|florauser|useradd|usermod)
			cat <<'EOF'
user-add <name> [group1,group2,...]   create a user (fresh uid/gid, own
                                        private group, locked password, home
                                        dir) -- see 'fau user-passwd' next
user-passwd <name>        set/change a user's password (interactive prompt)
user-rename <old> <new>   rename a user: passwd/shadow/group entries, group
                            memberships, and its home dir (if it's the
                            standard /home/<name> layout) all follow along.
                            Refuses to rename root.
user-groupadd <name> [gid]   create a new, empty group
user-addtogroup <user> <group>   add a user to an existing group
EOF
			;;
		bootstrap)
			cat <<'EOF'
build-time only (used by scripts/build-rootfs.sh, not meant for end users):
bootstrap <pkg> [pkg ...] install system package(s) into FAU_ROOT, with dependencies
bootstrap-remove <pkg> [pkg ...]
                          remove system package(s): files and system.json entry
                            (no dependency check; files still owned by another
                            installed package are left in place)
bootstrap-list            list installed system packages and versions
bootstrap-export [file]   write system.json to file (default: stdout)
bootstrap-apply [file]    install the exact system package set recorded in file
                            (default: system.json in the current directory)
EOF
			;;
		all)
			local t
			for t in install build repo export backup service seat user bootstrap; do
				echo "-- $t --"
				usage_topic "$t"
				echo
			done
			;;
		*)
			die "unknown help topic: $topic (see 'fau help' for the list)"
			;;
	esac
}

# Maps a command name to the fau-<name> tool that implements it, then execs
# it with the *original* command name still as $1 (each fau-<name> tool
# re-dispatches on that itself, the same way this file used to) followed by
# the rest of the original arguments. exec, not a plain call: a pure
# dispatcher has nothing left to do afterward, so replacing this process
# with the real tool is both simpler and propagates its exit status/signals
# directly instead of through an extra layer.
dispatch() {
	local cmd=$1; shift
	case "$cmd" in
		install|remove|list)
			exec "$SELF_DIR/fau-install" "$cmd" "$@" ;;
		build|build-list)
			exec "$SELF_DIR/fau-build" "$cmd" "$@" ;;
		repo-add|repo-index)
			exec "$SELF_DIR/fau-repo" "$cmd" "$@" ;;
		export|import)
			exec "$SELF_DIR/fau-export" "$cmd" "$@" ;;
		backup|backup-list|backup-remove|backup-restore|backup-repair)
			exec "$SELF_DIR/fau-backup" "$cmd" "$@" ;;
		service-list|service-status|service-enable|service-disable|service-start|service-stop|service-restart)
			exec "$SELF_DIR/fau-service" "$cmd" "$@" ;;
		seat-status|seat-switch)
			exec "$SELF_DIR/fau-seat" "$cmd" "$@" ;;
		user-add|user-passwd|user-rename|user-groupadd|user-addtogroup)
			exec "$SELF_DIR/fau-user" "$cmd" "$@" ;;
		bootstrap|bootstrap-remove|bootstrap-list|bootstrap-export|bootstrap-apply)
			exec "$SELF_DIR/fau-bootstrap" "$cmd" "$@" ;;
		*)
			die "unknown command: $cmd (see --help)"
			;;
	esac
}

main() {
	[ $# -ge 1 ] || { usage; exit 1; }
	local cmd=$1; shift
	case "$cmd" in
		-h|--help|help)
			if [ $# -ge 1 ]; then usage_topic "$1"; else usage; fi
			;;
		*)
			dispatch "$cmd" "$@"
			;;
	esac
}

main "$@"
