#!/usr/bin/env bash
# fau — FloraOS's package manager.
# Package format: <name>-<version>.fau.tar.zst, containing:
#   pkginfo   key=value metadata (name, version, description, depends, bin)
#   files/    payload
#
# Two install modes:
#   install / remove / list   — system packages, merged into FAU_ROOT (/usr, /etc, ...)
#   app-install / app-remove / app-list — user apps, each isolated under
#     FAU_APPS_DIR/<name>/ with its own config/cache/data/logs, never touching
#     the system root. See "bin" in pkginfo: comma-separated relative paths
#     under files/ that should get a PATH-visible wrapper.
set -euo pipefail

FAU_ROOT="${FAU_ROOT:-/}"
FAU_REPO_DIR="${FAU_REPO_DIR:-/etc/fau/repo}"
FAU_STATE_DIR="${FAU_ROOT%/}/var/lib/fau"
FAU_CACHE_DIR="${FAU_ROOT%/}/var/cache/fau/pkg"
FAU_SYSTEM_JSON="${FAU_STATE_DIR}/system.json"

FAU_APPS_DIR="${FAU_APPS_DIR:-$HOME/apps}"
FAU_APPS_BIN_DIR="${FAU_APPS_DIR}/.bin"
FAU_APPS_JSON="${FAU_APPS_DIR}/.fau-apps.json"

die() { echo "fau: error: $*" >&2; exit 1; }
log() { echo "fau: $*" >&2; }

usage() {
	cat <<'EOF'
usage: fau <command> [args]

commands:
  install <pkg> [pkg ...]   install system package(s) into FAU_ROOT, with dependencies
  remove <pkg> [pkg ...]    remove system package(s) (files only, no dependency check)
  list                      list installed system packages and versions
  export [file]             write system.json to file (default: stdout)
  apply <file>              install the exact system package set recorded in file

  app-install <pkg> [...]  install user app(s) into FAU_APPS_DIR/<name>/, isolated
  app-remove <pkg> [...]    remove user app(s) and their PATH wrappers
  app-list                 list installed user apps and versions

  repo-add <archive>        add a built .fau.tar.zst to the local repo and index it
  repo-index                rebuild repo.json from the archives present in the repo dir

environment:
  FAU_ROOT        target root for system packages (default: /)
  FAU_REPO_DIR    directory holding .fau.tar.zst archives + repo.json (default: /etc/fau/repo)
  FAU_APPS_DIR    directory for isolated user apps (default: $HOME/apps)
EOF
}

json_escape() {
	# minimal JSON string escaping for the fields we actually emit (no control chars expected)
	local s=$1
	s=${s//\\/\\\\}
	s=${s//\"/\\\"}
	printf '%s' "$s"
}

pkginfo_field() {
	# pkginfo_field <pkginfo-file> <key>
	grep "^$2=" "$1" 2>/dev/null | head -n1 | cut -d'=' -f2- || true
}

# --- dependency version constraints -----------------------------------------
# depends= entries may optionally carry a constraint: "name", "name>=1.2", or
# "name==1.2" (comma-separated, same as always). Deliberately just these two
# operators, both string-compared via `sort -V` (coreutils, already a base
# package) rather than a hand-rolled semver parser -- full range solving was
# already scoped out in ARCHITECTURE.md as more than this tool needs.

dep_parse() {
	# dep_parse <dep-token> -> prints "name<TAB>op<TAB>version" (op/version
	# empty if the token is a bare name)
	local dep=$1
	case "$dep" in
		*'>='*) printf '%s\t%s\t%s\n' "${dep%%>=*}" '>=' "${dep#*>=}" ;;
		*'=='*) printf '%s\t%s\t%s\n' "${dep%%==*}" '==' "${dep#*==}" ;;
		*) printf '%s\t\t\n' "$dep" ;;
	esac
}

version_satisfies() {
	# version_satisfies <installed> <op> <required> -- op may be empty (any
	# installed version satisfies an unconstrained dependency)
	local installed=$1 op=$2 required=$3
	case "$op" in
		'') return 0 ;;
		'==') [ "$installed" = "$required" ] ;;
		'>=')
			[ "$installed" = "$required" ] && return 0
			[ "$(printf '%s\n%s\n' "$installed" "$required" | sort -V | tail -n1)" = "$installed" ]
			;;
		*) die "unknown version constraint operator: $op" ;;
	esac
}

state_init() {
	mkdir -p "$FAU_STATE_DIR" "$FAU_CACHE_DIR"
	[ -f "$FAU_SYSTEM_JSON" ] || printf '{"packages":{}}\n' > "$FAU_SYSTEM_JSON"
}

apps_state_init() {
	mkdir -p "$FAU_APPS_DIR" "$FAU_APPS_BIN_DIR"
	[ -f "$FAU_APPS_JSON" ] || printf '{"packages":{}}\n' > "$FAU_APPS_JSON"
}

# --- manifest (system.json / apps.json) read/write --------------------------
# Flat schema only: {"packages":{"name":{"version":"x"},...}}. Hand-rolled
# parsing is fine at this scale; revisit if the schema grows. Both
# system.json and the per-user apps.json share this format and these helpers,
# parameterized by which file to operate on.

json_get_version() {
	# json_get_version <file> <name>  -> prints version or nothing
	local file=$1 name=$2
	grep -o "\"$name\"[[:space:]]*:[[:space:]]*{[[:space:]]*\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$file" 2>/dev/null \
		| sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/' || true
}

json_list_names() {
	local file=$1
	grep -oE '"[^"]+"[[:space:]]*:[[:space:]]*\{[[:space:]]*"version"' "$file" 2>/dev/null \
		| sed -E 's/^"([^"]+)".*/\1/' || true
}

json_set() {
	# json_set <file> <name> <version>  — add or update an entry
	local file=$1 name=$2 version=$3
	local tmp; tmp=$(mktemp)
	{
		echo '{"packages":{'
		local first=1
		for n in $(json_list_names "$file"); do
			[ "$n" = "$name" ] && continue
			local v; v=$(json_get_version "$file" "$n")
			[ $first -eq 1 ] || echo ','
			first=0
			printf '"%s":{"version":"%s"}' "$(json_escape "$n")" "$(json_escape "$v")"
		done
		[ $first -eq 1 ] || echo ','
		printf '"%s":{"version":"%s"}' "$(json_escape "$name")" "$(json_escape "$version")"
		echo
		echo '}}'
	} > "$tmp"
	mv "$tmp" "$file"
}

json_unset() {
	local file=$1 name=$2
	local tmp; tmp=$(mktemp)
	{
		echo '{"packages":{'
		local first=1
		for n in $(json_list_names "$file"); do
			[ "$n" = "$name" ] && continue
			local v; v=$(json_get_version "$file" "$n")
			[ $first -eq 1 ] || echo ','
			first=0
			printf '"%s":{"version":"%s"}' "$(json_escape "$n")" "$(json_escape "$v")"
		done
		echo
		echo '}}'
	} > "$tmp"
	mv "$tmp" "$file"
}

system_get_version() { json_get_version "$FAU_SYSTEM_JSON" "$1"; }
system_list_names() { json_list_names "$FAU_SYSTEM_JSON"; }
system_set() { json_set "$FAU_SYSTEM_JSON" "$1" "$2"; }
system_unset() { json_unset "$FAU_SYSTEM_JSON" "$1"; }

# --- repo --------------------------------------------------------------------

repo_json() { echo "${FAU_REPO_DIR%/}/repo.json"; }

repo_index() {
	local repo; repo=$(repo_json)
	mkdir -p "$FAU_REPO_DIR"
	local tmp; tmp=$(mktemp)
	{
		echo '{"packages":{'
		local first=1
		shopt -s nullglob
		for archive in "$FAU_REPO_DIR"/*.fau.tar.zst; do
			local work; work=$(mktemp -d)
			tar -I zstd -xf "$archive" -C "$work" pkginfo
			local name version sha
			name=$(pkginfo_field "$work/pkginfo" name)
			version=$(pkginfo_field "$work/pkginfo" version)
			sha=$(sha256sum "$archive" | cut -d' ' -f1)
			rm -rf "$work"
			[ $first -eq 1 ] || echo ','
			first=0
			printf '"%s":{"version":"%s","file":"%s","sha256":"%s"}' \
				"$(json_escape "$name")" "$(json_escape "$version")" \
				"$(json_escape "$(basename "$archive")")" "$sha"
		done
		echo
		echo '}}'
	} > "$tmp"
	mv "$tmp" "$repo"
	log "indexed $(basename "$FAU_REPO_DIR")"
}

repo_lookup_file() {
	# repo_lookup_file <name> -> prints archive filename, or nothing if
	# there's no repo index yet or the name isn't in it (not an error here --
	# callers that need a system package to exist check for an empty result
	# themselves; app_install_one falls back to pacman on an empty result)
	local name=$1 repo; repo=$(repo_json)
	[ -f "$repo" ] || return 0
	awk -v n="\"$name\"" '
		index($0, n":{") { in_pkg=1 }
		in_pkg && match($0, /"file":"[^"]*"/) {
			s = substr($0, RSTART, RLENGTH)
			sub(/"file":"/, "", s); sub(/"$/, "", s)
			print s; exit
		}
	' "$repo"
}

repo_lookup_depends() {
	local archive=$1
	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work" pkginfo
	pkginfo_field "$work/pkginfo" depends
	rm -rf "$work"
}

repo_add() {
	local archive=$1
	[ -f "$archive" ] || die "no such archive: $archive"
	mkdir -p "$FAU_REPO_DIR"

	# A repo directory must hold at most one archive per package name --
	# without this, repo_index (which just globs every *.fau.tar.zst) ends up
	# with duplicate keys for the same name after a version bump (the old
	# archive never gets removed on its own), and which one repo_lookup_file
	# resolves to then depends on filesystem glob order, not on which
	# version was actually just added.
	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work" pkginfo
	local incoming_name; incoming_name=$(pkginfo_field "$work/pkginfo" name)
	rm -rf "$work"
	if [ -n "$incoming_name" ]; then
		local existing existing_name w2
		shopt -s nullglob
		for existing in "$FAU_REPO_DIR"/*.fau.tar.zst; do
			[ "$(basename "$existing")" = "$(basename "$archive")" ] && continue
			w2=$(mktemp -d)
			tar -I zstd -xf "$existing" -C "$w2" pkginfo 2>/dev/null
			existing_name=$(pkginfo_field "$w2/pkginfo" name)
			rm -rf "$w2"
			[ "$existing_name" = "$incoming_name" ] && rm -f "$existing"
		done
		shopt -u nullglob
	fi

	cp "$archive" "$FAU_REPO_DIR/"
	repo_index
}

# --- install/remove ----------------------------------------------------------

install_one() {
	# install_one <name> [want-version] [ancestor-chain] -- want-version,
	# when given (used by cmd_apply), is enforced against the fau repo's own
	# recorded version: reproducibility from a system.json manifest is only
	# real if a version mismatch is a hard error, not a silent "install
	# whatever's there now". ancestor-chain is the colon-delimited list of
	# packages currently being installed up the call stack -- passed as a
	# plain argument (not a global) so each recursive branch gets its own
	# copy with nothing to clean up on return, and detects a circular
	# depends= (A -> B -> A) as a clear error instead of recursing until
	# bash gives up.
	local name=$1 want_version=${2:-} chain=${3:-}
	case ":$chain:" in
		*":$name:"*) die "circular dependency: $chain:$name" ;;
	esac
	local file; file=$(repo_lookup_file "$name")
	if [ -z "$file" ]; then
		if pacman_fallback_available; then
			[ -z "$want_version" ] || log "warning: $name isn't in the fau repo -- falling back to pacman, exact version $want_version can't be guaranteed"
			install_one_pacman "$name"
			return
		fi
		die "package not found in repo: $name (and no pacman mirrorlist/repo-list available to fall back to)"
	fi

	if [ -n "$want_version" ]; then
		local repo_version; repo_version=$(json_get_version "$(repo_json)" "$name")
		[ "$repo_version" = "$want_version" ] || \
			die "manifest wants $name $want_version, but the repo only has $repo_version -- rebuild/repo-add the exact pinned version first"
	fi

	local existing; existing=$(system_get_version "$name")
	local archive="${FAU_REPO_DIR%/}/${file}"

	local depends; depends=$(repo_lookup_depends "$archive")
	if [ -n "${depends:-}" ]; then
		# tr, not `local IFS=','`: IFS is function-scoped, not block-scoped,
		# so it would still be ',' for every command below this loop within
		# this same call (notably system_set's own word-splitting) -- that's
		# exactly what corrupted system.json before this fix.
		for dep in $(printf '%s' "$depends" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			local dep_name dep_op dep_ver
			IFS=$'\t' read -r dep_name dep_op dep_ver <<< "$(dep_parse "$dep")"
			local dep_installed; dep_installed=$(system_get_version "$dep_name")
			if [ -z "$dep_installed" ]; then
				install_one "$dep_name" "" "$chain:$name"
			elif ! version_satisfies "$dep_installed" "$dep_op" "$dep_ver"; then
				log "note: $dep_name $dep_installed is installed but $name needs $dep_name $dep_op$dep_ver -- reinstalling from the repo"
				install_one "$dep_name" "" "$chain:$name"
				dep_installed=$(system_get_version "$dep_name")
				version_satisfies "$dep_installed" "$dep_op" "$dep_ver" || \
					die "$name needs $dep_name $dep_op$dep_ver, but the repo only has $dep_installed"
			fi
		done
	fi

	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work"
	local version; version=$(pkginfo_field "$work/pkginfo" version)
	mkdir -p "$FAU_ROOT"
	# rsync -a alone replaces a destination symlink-to-directory (e.g. the
	# merged-/usr bin/sbin/lib/lib64 symlinks) with a real directory;
	# --keep-dirlinks (-K) keeps the symlink and merges into its target
	# instead, which is what installing multiple packages into one merged
	# root requires. Plain cp -a refuses the merge outright ("cannot
	# overwrite non-directory X with directory Y").
	# --checksum: without it, rsync's default quick-check (same size + same
	# mtime => skip) silently keeps the OLD file content on an upgrade
	# whenever two versions of a file happen to match in both -- reproduced
	# directly (a package bumped from 1.0 to 2.0 with same-size files kept
	# serving the 1.0 binary after "upgrading" to 2.0, with system.json
	# claiming 2.0 the whole time). Package archives aren't gigabytes, so
	# hashing every file on install is the correct trade, not a slow one.
	rsync -aK --checksum "$work/files/" "$FAU_ROOT/"
	rm -rf "$work"

	system_set "$name" "$version"
	if [ -n "$existing" ]; then
		log "upgraded $name $existing -> $version"
	else
		log "installed $name $version"
	fi
}

cmd_install() {
	[ $# -ge 1 ] || die "install requires at least one package name"
	state_init
	for name in "$@"; do install_one "$name"; done
}

cmd_remove() {
	[ $# -ge 1 ] || die "remove requires at least one package name"
	state_init
	for name in "$@"; do
		[ -n "$(system_get_version "$name")" ] || { log "$name is not installed, skipping"; continue; }
		system_unset "$name"
		log "removed $name from system.json (files left in place — fau does not track individual files yet)"
	done
}

cmd_list() {
	state_init
	for n in $(system_list_names); do
		printf '%s %s\n' "$n" "$(system_get_version "$n")"
	done
}

cmd_export() {
	state_init
	if [ $# -ge 1 ]; then cp "$FAU_SYSTEM_JSON" "$1"; else cat "$FAU_SYSTEM_JSON"; fi
}

cmd_apply() {
	[ $# -eq 1 ] || die "apply requires exactly one manifest file"
	local manifest=$1
	[ -f "$manifest" ] || die "no such file: $manifest"
	state_init
	# json_list_names/json_get_version already parse this exact
	# {"packages":{"name":{"version":"x"}}} shape (system.json's own format)
	# -- reusing them instead of a second hand-rolled regex is also what
	# surfaced this function used to read names only and silently drop the
	# version, so "apply" never actually verified it installed what the
	# manifest recorded.
	local n
	for n in $(json_list_names "$manifest"); do
		install_one "$n" "$(json_get_version "$manifest" "$n")"
	done
}

# --- app-install/app-remove/app-list -----------------------------------------
# Each app lives entirely under FAU_APPS_DIR/<name>/: its own files, plus
# config/cache/data/logs subdirs. Wrapper scripts in FAU_APPS_BIN_DIR (put
# that on PATH) set HOME/XDG_*_HOME to redirect the app into its own
# directory before exec'ing the real binary -- works for any app that
# follows the XDG Base Directory spec (most modern Linux software does).
# Apps that hardcode absolute paths won't cooperate; that's a known limit,
# not a bug.

app_wrapper_write() {
	# app_wrapper_write <name> <app-dir> <relbin>
	local name=$1 app_dir=$2 relbin=$3
	local cmd_name; cmd_name=$(basename "$relbin")
	local wrapper="$FAU_APPS_BIN_DIR/$cmd_name"
	local app_libdir="$app_dir/usr/lib:$app_dir/lib"
	cat > "$wrapper" <<-EOF
	#!/bin/sh
	export HOME="$app_dir"
	export XDG_CONFIG_HOME="$app_dir/config"
	export XDG_CACHE_HOME="$app_dir/cache"
	export XDG_DATA_HOME="$app_dir/data"
	export XDG_STATE_HOME="$app_dir/logs"
	export LD_LIBRARY_PATH="$app_libdir\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}"
	export PATH="$app_dir/usr/bin:$app_dir/bin\${PATH:+:\$PATH}"
	exec "$app_dir/$relbin" "\$@"
	EOF
	chmod 755 "$wrapper"
}

app_install_one() {
	# app_install_one <name> [ancestor-chain] -- see install_one's own
	# comment for why the chain is a plain argument, not a global.
	local name=$1 chain=${2:-}
	case ":$chain:" in
		*":$name:"*) die "circular dependency: $chain:$name" ;;
	esac
	local file; file=$(repo_lookup_file "$name")
	if [ -z "$file" ]; then
		if pacman_fallback_available; then
			app_install_one_pacman "$name"
			return
		fi
		die "package not found in repo: $name (and no pacman mirrorlist/repo-list available to fall back to)"
	fi

	local existing; existing=$(json_get_version "$FAU_APPS_JSON" "$name")
	local archive="${FAU_REPO_DIR%/}/${file}"

	local depends; depends=$(repo_lookup_depends "$archive")
	if [ -n "${depends:-}" ]; then
		for dep in $(printf '%s' "$depends" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			local dep_name dep_op dep_ver
			IFS=$'\t' read -r dep_name dep_op dep_ver <<< "$(dep_parse "$dep")"
			local dep_installed; dep_installed=$(json_get_version "$FAU_APPS_JSON" "$dep_name")
			if [ -z "$dep_installed" ]; then
				app_install_one "$dep_name" "$chain:$name"
			elif ! version_satisfies "$dep_installed" "$dep_op" "$dep_ver"; then
				log "note: $dep_name $dep_installed is installed but $name needs $dep_name $dep_op$dep_ver -- reinstalling from the repo"
				app_install_one "$dep_name" "$chain:$name"
				dep_installed=$(json_get_version "$FAU_APPS_JSON" "$dep_name")
				version_satisfies "$dep_installed" "$dep_op" "$dep_ver" || \
					die "$name needs $dep_name $dep_op$dep_ver, but the repo only has $dep_installed"
			fi
		done
	fi

	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work"
	local version bin; version=$(pkginfo_field "$work/pkginfo" version)
	bin=$(pkginfo_field "$work/pkginfo" bin)

	local app_dir="${FAU_APPS_DIR%/}/${name}"
	rm -rf "$app_dir"
	mkdir -p "$app_dir" "$app_dir/config" "$app_dir/cache" "$app_dir/data" "$app_dir/logs"
	cp -a "$work/files/." "$app_dir"
	cp "$work/pkginfo" "$app_dir/.pkginfo"
	rm -rf "$work"

	if [ -z "${bin:-}" ] && [ -d "$app_dir/bin" ]; then
		bin=$(find "$app_dir/bin" -maxdepth 1 -type f -printf 'bin/%f,' 2>/dev/null)
	fi
	if [ -n "${bin:-}" ]; then
		for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
			relbin=$(echo "$relbin" | xargs)
			[ -z "$relbin" ] && continue
			app_wrapper_write "$name" "$app_dir" "$relbin"
		done
	fi

	json_set "$FAU_APPS_JSON" "$name" "$version"
	if [ -n "$existing" ]; then
		log "upgraded app $name $existing -> $version"
	else
		log "installed app $name $version into $app_dir"
	fi
	case ":$PATH:" in
		*":$FAU_APPS_BIN_DIR:"*) ;;
		*) log "note: $FAU_APPS_BIN_DIR is not on your PATH yet — add it to use $name's commands directly" ;;
	esac
}

# --- pacman-backed fallback ---------------------------------------------------
# Until FloraOS has its own curated app catalog, install/app-install fall
# back to pulling from Arch/Artix's own repos when a package isn't in the
# local fau repo. This never shells out to the `pacman` binary at all --
# only its *data formats* (sync db, desc files, mirrorlist, pacman.conf's
# repo list) are read directly, using fau's own fetch/resolve/verify code.
# That means this fallback works both at build time (reading this build
# host's own /etc/pacman.d/mirrorlist and /var/lib/pacman/sync as a fast
# path) and from inside an already-booted FloraOS system, which has neither
# pacman nor a synced db -- it falls back to fetching the mirrorlist/db
# fresh from a mirror, using a copy of the mirrorlist/repo-list FloraOS
# ships at /etc/fau/ specifically for this (see build-rootfs.sh).
# Real caveat: fetched binaries are built against Artix's glibc -- this only
# works cleanly as long as that stays ABI-compatible with FloraOS's own
# from-scratch glibc (currently identical versions by coincidence, not by
# any guarantee). GUI apps also won't have a display server to draw on yet
# (see ARCHITECTURE.md) -- this gets you the files, not a running X11.

pacman_mirrorlist_path() {
	local candidate
	for candidate in /etc/pacman.d/mirrorlist "${FAU_ROOT%/}/etc/fau/pacman-mirrorlist"; do
		[ -f "$candidate" ] && { echo "$candidate"; return 0; }
	done
	return 1
}

pacman_repo_list_path() {
	local candidate
	for candidate in /etc/pacman.conf "${FAU_ROOT%/}/etc/fau/pacman-repos"; do
		[ -f "$candidate" ] && { echo "$candidate"; return 0; }
	done
	return 1
}

pacman_fallback_available() {
	pacman_mirrorlist_path >/dev/null 2>&1 && pacman_repo_list_path >/dev/null 2>&1
}

pacman_repo_names() {
	# Priority order matters: the first repo that has a given name wins,
	# same as pacman.conf's own section ordering.
	local f; f=$(pacman_repo_list_path) || die "no pacman mirrorlist/repo-list available"
	case "$(basename "$f")" in
		pacman.conf) grep -oE '^\[[a-zA-Z0-9_.-]+\]' "$f" | tr -d '[]' | grep -vx options ;;
		*) grep -vE '^[[:space:]]*(#|$)' "$f" ;;
	esac
}

pacman_mirror_url() {
	# pacman_mirror_url <repo> <filename> -> first configured mirror's URL
	local repo=$1 filename=$2
	local mirrorlist; mirrorlist=$(pacman_mirrorlist_path) || die "no pacman mirrorlist available"
	local tmpl; tmpl=$(grep -m1 '^Server' "$mirrorlist" | sed 's/^Server[[:space:]]*=[[:space:]]*//')
	[ -n "$tmpl" ] || die "no Server= line found in $mirrorlist"
	local arch; arch=$(uname -m)
	tmpl=${tmpl//\$repo/$repo}
	tmpl=${tmpl//\$arch/$arch}
	echo "$tmpl/$filename"
}

pacman_db_cache_dir() {
	local d; d="${FAU_CACHE_DIR%/}/pacman-db"
	mkdir -p "$d"
	echo "$d"
}

pacman_fetch_repo_db() {
	# pacman_fetch_repo_db <repo> -> local path to <repo>.db, downloading if
	# not already cached. Prefers this build host's own already-synced copy
	# (fast path, no network needed) over a fresh mirror fetch -- the fresh
	# fetch is what makes this work from inside a booted FloraOS system,
	# which has neither pacman nor a populated /var/lib/pacman/sync.
	local repo=$1
	local cache_dir; cache_dir=$(pacman_db_cache_dir)
	local dest="$cache_dir/$repo.db"
	if [ ! -s "$dest" ]; then
		if [ -r "/var/lib/pacman/sync/$repo.db" ]; then
			cp "/var/lib/pacman/sync/$repo.db" "$dest"
		else
			local url; url=$(pacman_mirror_url "$repo" "$repo.db")
			curl -fsSL -o "$dest.part" "$url" || die "failed to fetch $repo.db from $url"
			mv "$dest.part" "$dest"
		fi
	fi
	echo "$dest"
}

# Field separator for fau's own pacman-resolution records (index lines,
# resolver output) -- NOT a literal tab. bash's `read` silently collapses
# *consecutive* IFS-whitespace separators (tab counts as whitespace no
# matter what IFS is set to), which corrupts parsing the instant a field in
# the middle is empty (e.g. a package with no depends or no provides) --
# every field after it silently shifts by one position. Found by tracing a
# real resolution: linux-api-headers (empty depends+provides) ended up
# looking like it "depended on" its own filename. \x1f (ASCII unit
# separator) isn't whitespace, so bash's read preserves empty fields
# correctly; verified directly (see the fix commit) before relying on it.
PACMAN_FS=$'\x1f'

pacman_repo_index() {
	# pacman_repo_index <repo> -> path to a cached index of every package in
	# that repo's sync db, one line each: name<FS>version<FS>depends<FS>provides<FS>filename<FS>sha256
	# (FS = $PACMAN_FS). Built once per repo. A real Arch repo can hold
	# thousands of packages (the "world" repo here has ~7300) -- spawning a
	# handful of awk processes per package to pull each field separately
	# (the first version of this) meant tens of thousands of forks and was
	# slow enough to look hung. A single awk invocation reading every
	# extracted desc file as its argument list, tracking one package's
	# fields across FNR==1 boundaries, does the entire repo in one process.
	local repo=$1
	local cache_dir; cache_dir=$(pacman_db_cache_dir)
	local index="$cache_dir/$repo.index"
	if [ ! -s "$index" ]; then
		local db; db=$(pacman_fetch_repo_db "$repo")
		local work; work=$(mktemp -d)
		tar -xzf "$db" -C "$work"
		local tmp; tmp=$(mktemp)
		awk -v ofs="$PACMAN_FS" '
			function emit() {
				if (name != "") {
					printf "%s%s%s%s%s%s%s%s%s%s%s\n", \
						name, ofs, version, ofs, depends, ofs, provides, ofs, filename, ofs, sha256
				}
			}
			FNR==1 { emit(); name=""; version=""; depends=""; provides=""; filename=""; sha256=""; field="" }
			/^%NAME%$/      { field="NAME"; next }
			/^%VERSION%$/   { field="VERSION"; next }
			/^%FILENAME%$/  { field="FILENAME"; next }
			/^%SHA256SUM%$/ { field="SHA256SUM"; next }
			/^%DEPENDS%$/   { field="DEPENDS"; next }
			/^%PROVIDES%$/  { field="PROVIDES"; next }
			/^%/            { field=""; next }
			/^$/            { field=""; next }
			field=="NAME"      { name=$0 }
			field=="VERSION"   { version=$0 }
			field=="FILENAME"  { filename=$0 }
			field=="SHA256SUM" { sha256=$0 }
			field=="DEPENDS"   { depends = (depends=="" ? $0 : depends","$0) }
			field=="PROVIDES"  { provides = (provides=="" ? $0 : provides","$0) }
			END { emit() }
		' "$work"/*/desc > "$tmp"
		mv "$tmp" "$index"
		rm -rf "$work"
	fi
	echo "$index"
}

# --- version comparison (pacman/alpm's algorithm, no pacman binary needed) ---
# Arch dependency constraints look like "glibc>=2.38-1" or "libfoo=1.2-3".
# Verified against the real `vercmp` binary across ~300 real package
# versions from this host's own sync dbs plus a battery of hand-picked
# cases (epoch, pkgrel, git-describe-style "+r37+gHASH" suffixes) -- exact
# match on all of them. The only known divergences from real vercmp are
# contrived synthetic cases (a bare alpha suffix directly attached with no
# separator, e.g. "1.0a" vs "1.0", and tilde pre-release markers) that
# essentially never occur in real Arch/Artix package version strings, which
# use "-", "+", "." as explicit separators -- an accepted, documented
# simplification rather than a full reimplementation of every rpmvercmp
# edge case.

_rpmvercmp() {
	local a=$1 b=$2
	[ "$a" = "$b" ] && { echo 0; return; }

	while [ -n "$a" ] || [ -n "$b" ]; do
		while [ -n "$a" ]; do
			case "${a:0:1}" in
				[A-Za-z0-9~]) break ;;
				*) a=${a:1} ;;
			esac
		done
		while [ -n "$b" ]; do
			case "${b:0:1}" in
				[A-Za-z0-9~]) break ;;
				*) b=${b:1} ;;
			esac
		done

		if [ "${a:0:1}" = "~" ] || [ "${b:0:1}" = "~" ]; then
			if [ "${a:0:1}" != "~" ]; then echo 1; return; fi
			if [ "${b:0:1}" != "~" ]; then echo -1; return; fi
			a=${a:1}; b=${b:1}
			continue
		fi

		if [ -z "$a" ] || [ -z "$b" ]; then break; fi

		local seg_a="" seg_b="" isnum=0
		if [[ "${a:0:1}" =~ [0-9] ]]; then
			isnum=1
			while [[ -n "${a:0:1}" && "${a:0:1}" =~ [0-9] ]]; do seg_a="$seg_a${a:0:1}"; a=${a:1}; done
			while [[ -n "${b:0:1}" && "${b:0:1}" =~ [0-9] ]]; do seg_b="$seg_b${b:0:1}"; b=${b:1}; done
		else
			while [[ -n "${a:0:1}" && "${a:0:1}" =~ [A-Za-z] ]]; do seg_a="$seg_a${a:0:1}"; a=${a:1}; done
			while [[ -n "${b:0:1}" && "${b:0:1}" =~ [A-Za-z] ]]; do seg_b="$seg_b${b:0:1}"; b=${b:1}; done
		fi

		if [ -z "$seg_b" ]; then
			if [ -z "$seg_a" ]; then continue; fi
			if [ "$isnum" -eq 1 ]; then echo 1; else echo -1; fi
			return
		fi
		if [ -z "$seg_a" ]; then echo -1; return; fi

		if [ "$isnum" -eq 1 ]; then
			seg_a=$(printf '%s' "$seg_a" | sed 's/^0*//')
			seg_b=$(printf '%s' "$seg_b" | sed 's/^0*//')
			if [ "${#seg_a}" -gt "${#seg_b}" ]; then echo 1; return; fi
			if [ "${#seg_b}" -gt "${#seg_a}" ]; then echo -1; return; fi
		fi

		if [ "$seg_a" != "$seg_b" ]; then
			if [[ "$seg_a" < "$seg_b" ]]; then echo -1; else echo 1; fi
			return
		fi
	done

	if [ -z "$a" ] && [ -z "$b" ]; then echo 0; return; fi
	if [ -z "$a" ]; then echo -1; else echo 1; fi
}

alpm_vercmp() {
	# alpm_vercmp <v1> <v2> -> -1, 0, or 1. Format: [epoch:]pkgver[-pkgrel]
	local v1=$1 v2=$2
	[ "$v1" = "$v2" ] && { echo 0; return; }

	local e1 e2 pv1 pv2 pr1 pr2
	case "$v1" in *:*) e1=${v1%%:*}; pv1=${v1#*:} ;; *) e1=0; pv1=$v1 ;; esac
	case "$v2" in *:*) e2=${v2%%:*}; pv2=${v2#*:} ;; *) e2=0; pv2=$v2 ;; esac

	if [ "$e1" != "$e2" ]; then
		if [ "$e1" -gt "$e2" ] 2>/dev/null; then echo 1; else echo -1; fi
		return
	fi

	case "$pv1" in *-*) pr1=${pv1##*-}; pv1=${pv1%-*} ;; *) pr1="" ;; esac
	case "$pv2" in *-*) pr2=${pv2##*-}; pv2=${pv2%-*} ;; *) pr2="" ;; esac

	local cmp; cmp=$(_rpmvercmp "$pv1" "$pv2")
	if [ "$cmp" -ne 0 ]; then echo "$cmp"; return; fi

	if [ -n "$pr1" ] && [ -n "$pr2" ]; then
		_rpmvercmp "$pr1" "$pr2"
		return
	fi
	echo 0
}

version_satisfies_alpm() {
	# version_satisfies_alpm <installed> <op> <required> -- op empty means
	# an unconstrained dependency, always satisfied
	local installed=$1 op=$2 required=$3
	[ -z "$op" ] && return 0
	local cmp; cmp=$(alpm_vercmp "$installed" "$required")
	case "$op" in
		'<') [ "$cmp" -lt 0 ] ;;
		'<=') [ "$cmp" -le 0 ] ;;
		'='|'==') [ "$cmp" -eq 0 ] ;;
		'>=') [ "$cmp" -ge 0 ] ;;
		'>') [ "$cmp" -gt 0 ] ;;
		*) return 0 ;;
	esac
}

alpm_dep_parse() {
	# alpm_dep_parse <dep-token> -> "name<FS>op<FS>version" (FS =
	# $PACMAN_FS; op/version empty for an unconstrained dependency). Longer
	# operators (>=, <=) must be checked before the bare >/< they contain
	# as a substring.
	local dep=$1
	case "$dep" in
		*'>='*) printf "%s${PACMAN_FS}%s${PACMAN_FS}%s\n" "${dep%%>=*}" '>=' "${dep#*>=}" ;;
		*'<='*) printf "%s${PACMAN_FS}%s${PACMAN_FS}%s\n" "${dep%%<=*}" '<=' "${dep#*<=}" ;;
		*'='*)  printf "%s${PACMAN_FS}%s${PACMAN_FS}%s\n" "${dep%%=*}" '=' "${dep#*=}" ;;
		*'>'*)  printf "%s${PACMAN_FS}%s${PACMAN_FS}%s\n" "${dep%%>*}" '>' "${dep#*>}" ;;
		*'<'*)  printf "%s${PACMAN_FS}%s${PACMAN_FS}%s\n" "${dep%%<*}" '<' "${dep#*<}" ;;
		*) printf "%s${PACMAN_FS}${PACMAN_FS}\n" "$dep" ;;
	esac
}

# --- dependency resolution (PROVIDES + version-aware, no pacman binary) -----

pacman_find_provider() {
	# pacman_find_provider <name> <op> <ver> -> "repo<FS>name<FS>version<FS>depends<FS>filename<FS>sha256"
	# (FS = $PACMAN_FS) for the first package (searched in repo priority
	# order) satisfying it, by exact name first, then by PROVIDES (virtual
	# package) if no repo has a real package by that name.
	local want=$1 op=$2 ver=$3
	local repo index line
	for repo in $(pacman_repo_names); do
		index=$(pacman_repo_index "$repo")
		# Index lines are name/version/depends/provides/filename/sha256 (6
		# fields) -- drop the provides field (unused by callers) so both
		# branches of this function emit the same 6-field shape prefixed
		# with repo; a mismatch here previously misaligned every field
		# after it for the caller (filename/sha256 silently swapped).
		line=$(awk -F"$PACMAN_FS" -v n="$want" -v fs="$PACMAN_FS" \
			'$1==n{print $1 fs $2 fs $3 fs $5 fs $6; exit}' "$index")
		[ -z "$line" ] && continue
		local pver; pver=$(printf '%s' "$line" | cut -d "$PACMAN_FS" -f2)
		if version_satisfies_alpm "$pver" "$op" "$ver"; then
			printf "%s${PACMAN_FS}%s\n" "$repo" "$line"
			return 0
		fi
	done
	for repo in $(pacman_repo_names); do
		index=$(pacman_repo_index "$repo")
		while IFS="$PACMAN_FS" read -r name version depends provides filename sha256; do
			[ -z "$name" ] || [ -z "$provides" ] && continue
			local prov
			for prov in $(printf '%s' "$provides" | tr ',' ' '); do
				local prov_name prov_ver
				case "$prov" in
					*=*) prov_name=${prov%%=*}; prov_ver=${prov#*=} ;;
					*) prov_name=$prov; prov_ver="" ;;
				esac
				[ "$prov_name" = "$want" ] || continue
				if [ -z "$op" ] && [ -n "$prov_ver" ] || version_satisfies_alpm "$prov_ver" "$op" "$ver"; then
					printf "%s${PACMAN_FS}%s${PACMAN_FS}%s${PACMAN_FS}%s${PACMAN_FS}%s${PACMAN_FS}%s\n" \
						"$repo" "$name" "$version" "$depends" "$filename" "$sha256"
					return 0
				fi
			done
		done < "$index"
	done
	return 1
}

_pacman_resolve_one() {
	# Appends "repo\tname\tversion\tfilename\tsha256" lines to out_file for
	# spec and everything it (transitively) depends on, dependencies before
	# dependents, each name resolved at most once (seen_file). Returns 1
	# only if *this exact* spec can't be found anywhere; a failure deeper in
	# the tree is logged and skipped rather than propagated, since Arch
	# dependency graphs commonly reference optional/soft deps this fallback
	# doesn't need to take literally.
	local spec=$1 seen_file=$2 out_file=$3
	local name op ver
	IFS="$PACMAN_FS" read -r name op ver <<< "$(alpm_dep_parse "$spec")"

	grep -qxF "$name" "$seen_file" 2>/dev/null && return 0

	local found
	found=$(pacman_find_provider "$name" "$op" "$ver") || return 1
	local repo pname pversion pdepends pfilename psha256
	IFS="$PACMAN_FS" read -r repo pname pversion pdepends pfilename psha256 <<< "$found"

	echo "$name" >> "$seen_file"
	# A dependency spec doesn't always name the real package directly -- it
	# can reference a virtual/soname alias (e.g. "libz.so=1-64") that
	# resolves to a differently-named real package (zlib). Without also
	# tracking the *resolved* name, that real package gets reprocessed (and
	# printed) once per distinct alias it's reached through -- found by
	# comparing cava's full closure against real pacman's own resolution:
	# unique package counts matched exactly, but the raw output had ~40
	# duplicate lines.
	if [ "$pname" != "$name" ]; then
		grep -qxF "$pname" "$seen_file" 2>/dev/null && return 0
		echo "$pname" >> "$seen_file"
	fi

	if [ -n "$pdepends" ]; then
		local d
		for d in $(printf '%s' "$pdepends" | tr ',' ' '); do
			[ -z "$d" ] && continue
			_pacman_resolve_one "$d" "$seen_file" "$out_file" \
				|| log "warning: couldn't resolve '$d' (a dependency of $pname) in any repo -- skipping it"
		done
	fi
	printf "%s${PACMAN_FS}%s${PACMAN_FS}%s${PACMAN_FS}%s${PACMAN_FS}%s\n" "$repo" "$pname" "$pversion" "$pfilename" "$psha256" >> "$out_file"
	return 0
}

pacman_resolve() {
	# pacman_resolve <name> -> prints "repo<FS>name<FS>version<FS>filename<FS>sha256"
	# (FS = $PACMAN_FS) lines for name and its full transitive closure, deps before dependents
	local name=$1
	local seen; seen=$(mktemp)
	local out; out=$(mktemp)
	if ! _pacman_resolve_one "$name" "$seen" "$out"; then
		rm -f "$seen" "$out"
		return 1
	fi
	cat "$out"
	rm -f "$seen" "$out"
}

install_one_pacman() {
	# System-side counterpart to app_install_one_pacman: merges into
	# FAU_ROOT (rsync -aK, same as install_one's own merge) and records into
	# system.json, instead of isolating into FAU_APPS_DIR. Used for base
	# packages fetched straight from Arch/Artix's own repos rather than
	# compiled from source (e.g. fastfetch during rootfs build).
	local name=$1
	local resolved; resolved=$(pacman_resolve "$name") \
		|| die "couldn't resolve '$name' in any configured pacman repo"

	mkdir -p "$FAU_ROOT"
	local fetch_dir; fetch_dir=$(mktemp -d)
	local version=""

	while IFS="$PACMAN_FS" read -r repo pkgname pkgversion filename sha256; do
		[ -n "$pkgname" ] || continue
		# pacman_resolve's closure for a package like fastfetch/libgcc also
		# includes glibc, filesystem, tzdata, etc: things FloraOS already
		# built from its own pinned source. Without this guard those get
		# rsync-merged over FAU_ROOT too, silently replacing FloraOS's own
		# compiled binaries with Arch's official ones -- found by comparing
		# libc.so.6's sha256 before/after a real build: the shipped one
		# turned out to be Arch's, not FloraOS's own.
		if [ "$pkgname" != "$name" ] && [ -n "$(system_get_version "$pkgname")" ]; then
			log "skipping $pkgname -- already provided by FloraOS's own build"
			continue
		fi
		# "filesystem" is Arch/Artix's own base-system bootstrap package --
		# never something the *requested* package (fastfetch/libgcc) needs
		# to run, only ever dragged in because Arch's dependency graph
		# implies "a base Arch system" underneath everything. Its content
		# outside etc/ and usr/include (already stripped below) is entirely
		# Arch/Artix distro integration -- /usr/lib/tmpfiles.d/artix.conf,
		# /usr/lib/sysctl.d/10-artix.conf, /usr/lib/sysusers.d/artix.conf,
		# Artix branding pixmaps -- and merging it in silently applied
		# Artix's own sysctl tuning at boot and threw tmpfiles errors for
		# /etc files this build deliberately doesn't ship (found on a real
		# boot, not by inspection). Skipped by name rather than stripping a
		# fifth individual subdirectory: none of "filesystem" is ever
		# wanted here, regardless of what FloraOS itself provides.
		if [ "$pkgname" = "filesystem" ]; then
			log "skipping $pkgname -- Arch/Artix base-system bootstrap package, not something $name needs to run"
			continue
		fi
		[ -n "$filename" ] && [ -n "$sha256" ] || die "missing metadata for $pkgname in repo $repo"

		local dest="$fetch_dir/$filename"
		if [ -r "/var/cache/pacman/pkg/$filename" ]; then
			cp "/var/cache/pacman/pkg/$filename" "$dest"
		else
			local url; url=$(pacman_mirror_url "$repo" "$filename")
			curl -fsSL -o "$dest" "$url" || die "failed to fetch $pkgname from $url"
		fi
		local actual; actual=$(sha256sum "$dest" | cut -d' ' -f1)
		[ "$actual" = "$sha256" ] || die "checksum mismatch for $pkgname: expected $sha256, got $actual"

		local extract_dir; extract_dir=$(mktemp -d)
		tar --zstd -xf "$dest" -C "$extract_dir"
		# Some packages (dbus's daemon-launch-helper, for one) ship
		# intentionally unreadable setuid-root helpers as a hardening
		# measure -- meaningless in this unprivileged, non-system-installed
		# copy, but it breaks the merge step below since we can't even read
		# what we just extracted. u+rX ensures we always can.
		chmod -R u+rX "$extract_dir"
		rm -f "$extract_dir/.PKGINFO" "$extract_dir/.BUILDINFO" "$extract_dir/.MTREE" "$extract_dir/.INSTALL"
		# FloraOS's own skeleton (apply-skeleton.sh) is the sole source of
		# truth for /etc -- a pacman-resolved dependency like Arch's
		# "filesystem" package ships its own /etc/artix-release,
		# /etc/shells, /etc/securetty, /etc/host.conf, etc, which would
		# otherwise land straight in FAU_ROOT/etc right alongside (and
		# contradicting) FloraOS's own identity files. System packages
		# fetched this way may only ever contribute to /usr.
		rm -rf "$extract_dir/etc"
		# /usr/include is dev-time-only (headers, never dlopen'd/exec'd at
		# runtime) -- resolving fastfetch/libgcc's full closure also pulls
		# in "linux-api-headers" purely because it's one of glibc's own
		# build-time dependencies on Arch, and it alone added 15MB of unused
		# kernel headers to the shipped image (measured on a real build).
		rm -rf "$extract_dir/usr/include"
		[ "$pkgname" = "$name" ] && version=$pkgversion
		# --checksum: see install_one's own merge for why plain -aK isn't
		# enough on an upgrade.
		rsync -aK --checksum "$extract_dir/" "$FAU_ROOT/"
		rm -rf "$extract_dir"
	done <<< "$resolved"
	rm -rf "$fetch_dir"

	system_set "$name" "${version:-unknown (via pacman)}"
	log "installed $name ${version:-(via pacman)} into $FAU_ROOT"
}

app_install_one_pacman() {
	local name=$1
	local resolved; resolved=$(pacman_resolve "$name") \
		|| die "couldn't resolve '$name' in any configured pacman repo"

	local app_dir="${FAU_APPS_DIR%/}/${name}"
	rm -rf "$app_dir"
	mkdir -p "$app_dir" "$app_dir/config" "$app_dir/cache" "$app_dir/data" "$app_dir/logs"
	local fetch_dir; fetch_dir=$(mktemp -d)
	local target_files version=""

	while IFS="$PACMAN_FS" read -r repo pkgname pkgversion filename sha256; do
		[ -n "$pkgname" ] || continue
		[ -n "$filename" ] && [ -n "$sha256" ] || die "missing metadata for $pkgname in repo $repo"

		local dest="$fetch_dir/$filename"
		if [ -r "/var/cache/pacman/pkg/$filename" ]; then
			cp "/var/cache/pacman/pkg/$filename" "$dest"
		else
			local url; url=$(pacman_mirror_url "$repo" "$filename")
			curl -fsSL -o "$dest" "$url" || die "failed to fetch $pkgname from $url"
		fi
		local actual; actual=$(sha256sum "$dest" | cut -d' ' -f1)
		[ "$actual" = "$sha256" ] || die "checksum mismatch for $pkgname: expected $sha256, got $actual"

		local extract_dir; extract_dir=$(mktemp -d)
		tar --zstd -xf "$dest" -C "$extract_dir"
		# Some packages (dbus's daemon-launch-helper, for one) ship
		# intentionally unreadable setuid-root helpers as a hardening
		# measure -- meaningless in this unprivileged, non-system-installed
		# copy, but it breaks the merge step below since we can't even read
		# what we just extracted. u+rX ensures we always can.
		chmod -R u+rX "$extract_dir"
		rm -f "$extract_dir/.PKGINFO" "$extract_dir/.BUILDINFO" "$extract_dir/.MTREE" "$extract_dir/.INSTALL"
		if [ "$pkgname" = "$name" ]; then
			version=$pkgversion
			target_files=$(cd "$extract_dir" && find usr/bin bin -maxdepth 1 -type f 2>/dev/null; true)
		fi
		cp -a "$extract_dir/." "$app_dir"
		rm -rf "$extract_dir"
	done <<< "$resolved"
	rm -rf "$fetch_dir"

	for relbin in $target_files; do
		app_wrapper_write "$name" "$app_dir" "$relbin"
	done

	# Without this, app-remove can't find which wrapper scripts belong to
	# this app (it reads bin= from .pkginfo, same as the repo-based
	# app_install_one does) -- confirmed by a real app-install/app-remove
	# round-trip: the wrapper in FAU_APPS_BIN_DIR survived "removal" and
	# failed with "No such file or directory" on next use.
	{
		echo "name=$name"
		echo "version=${version:-unknown (via pacman)}"
		printf 'bin='
		printf '%s' "$target_files" | tr '\n' ','
		echo
	} > "$app_dir/.pkginfo"

	json_set "$FAU_APPS_JSON" "$name" "${version:-unknown (via pacman)}"
	log "installed app $name (via pacman) into $app_dir"
	[ -n "$target_files" ] || log "note: couldn't find any usr/bin or bin entrypoint owned by $name to wrap"
	case ":$PATH:" in
		*":$FAU_APPS_BIN_DIR:"*) ;;
		*) log "note: $FAU_APPS_BIN_DIR is not on your PATH yet — add it to use $name's commands directly" ;;
	esac
}

cmd_app_install() {
	[ $# -ge 1 ] || die "app-install requires at least one package name"
	apps_state_init
	for name in "$@"; do app_install_one "$name"; done
}

cmd_app_remove() {
	[ $# -ge 1 ] || die "app-remove requires at least one package name"
	apps_state_init
	for name in "$@"; do
		[ -n "$(json_get_version "$FAU_APPS_JSON" "$name")" ] || { log "app $name is not installed, skipping"; continue; }
		local app_dir="${FAU_APPS_DIR%/}/${name}"
		local bin; bin=$([ -f "$app_dir/.pkginfo" ] && pkginfo_field "$app_dir/.pkginfo" bin || true)
		if [ -n "${bin:-}" ]; then
			for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
				relbin=$(echo "$relbin" | xargs)
				[ -z "$relbin" ] && continue
				rm -f "$FAU_APPS_BIN_DIR/$(basename "$relbin")"
			done
		fi
		rm -rf "$app_dir"
		json_unset "$FAU_APPS_JSON" "$name"
		log "removed app $name (including its config/cache/data/logs)"
	done
}

cmd_app_list() {
	apps_state_init
	for n in $(json_list_names "$FAU_APPS_JSON"); do
		printf '%s %s\n' "$n" "$(json_get_version "$FAU_APPS_JSON" "$n")"
	done
}

main() {
	[ $# -ge 1 ] || { usage; exit 1; }
	local cmd=$1; shift
	case "$cmd" in
		install) cmd_install "$@" ;;
		remove) cmd_remove "$@" ;;
		list) cmd_list "$@" ;;
		export) cmd_export "$@" ;;
		apply) cmd_apply "$@" ;;
		app-install) cmd_app_install "$@" ;;
		app-remove) cmd_app_remove "$@" ;;
		app-list) cmd_app_list "$@" ;;
		repo-add) repo_add "$@" ;;
		repo-index) repo_index "$@" ;;
		-h|--help|help) usage ;;
		*) die "unknown command: $cmd (see --help)" ;;
	esac
}

main "$@"
