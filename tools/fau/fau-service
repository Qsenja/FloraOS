#!/usr/bin/env bash
# fau-service -- a thin front end over OpenRC (rc-update/rc-service). See fau.md.
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"

INIT_D_DIR="/etc/init.d"
RUNLEVELS_DIR="/etc/runlevels"

service_check_exists() {
	local name=$1
	[ -n "$name" ] || die "service name required"
	[ -x "$INIT_D_DIR/$name" ] || die "no such service: $name (see 'fau service-list')"
}

service_runlevels() {
	# Explicit `return 0` matters here -- see fau.md for the real bug this fixes.
	local name=$1 rl
	[ -d "$RUNLEVELS_DIR" ] || return 0
	for rl in "$RUNLEVELS_DIR"/*/; do
		[ -e "${rl}${name}" ] && basename "$rl"
	done
	return 0
}

service_state() {
	local name=$1
	if [ -e "/run/openrc/started/$name" ]; then echo started
	elif [ -e "/run/openrc/failed/$name" ]; then echo failed
	elif [ -e "/run/openrc/inactive/$name" ]; then echo inactive
	else echo stopped
	fi
}

cmd_service_list() {
	[ $# -eq 0 ] || die "service-list takes no arguments"
	[ -d "$INIT_D_DIR" ] || die "no $INIT_D_DIR -- is this a real OpenRC system?"
	local f name runlevels state
	for f in "$INIT_D_DIR"/*; do
		[ -f "$f" ] || continue
		name=$(basename "$f")
		[ "$name" = functions.sh ] && continue
		runlevels=$(service_runlevels "$name" | paste -sd, -)
		state=$(service_state "$name")
		printf '%-20s %-9s %s\n' "$name" "$state" "${runlevels:-(none)}"
	done
}

cmd_service_status() {
	[ $# -eq 1 ] || die "usage: fau service-status <name>"
	service_check_exists "$1"
	local state; state=$(service_state "$1")
	local runlevels; runlevels=$(service_runlevels "$1" | paste -sd, -)
	echo "$1: $state (runlevels: ${runlevels:-none})"
}

cmd_service_enable() {
	[ $# -ge 1 ] && [ $# -le 2 ] || die "usage: fau service-enable <name> [runlevel]"
	local name=$1 runlevel=${2:-default}
	service_check_exists "$name"
	[ -d "$RUNLEVELS_DIR/$runlevel" ] || die "no such runlevel: $runlevel"
	rc-update add "$name" "$runlevel" || die "rc-update add $name $runlevel failed"
	log "$name enabled in runlevel $runlevel"
}

cmd_service_disable() {
	[ $# -ge 1 ] && [ $# -le 2 ] || die "usage: fau service-disable <name> [runlevel]"
	local name=$1 runlevel=${2:-default}
	service_check_exists "$name"
	rc-update del "$name" "$runlevel" || die "rc-update del $name $runlevel failed"
	log "$name disabled in runlevel $runlevel"
}

cmd_service_start()   { [ $# -eq 1 ] || die "usage: fau service-start <name>";   service_check_exists "$1"; rc-service "$1" start; }
cmd_service_stop()    { [ $# -eq 1 ] || die "usage: fau service-stop <name>";    service_check_exists "$1"; rc-service "$1" stop; }
cmd_service_restart() { [ $# -eq 1 ] || die "usage: fau service-restart <name>"; service_check_exists "$1"; rc-service "$1" restart; }

cmd=${1:-}; [ $# -ge 1 ] && shift

case "$cmd" in
	service-list) cmd_service_list "$@" ;;
	service-status) cmd_service_status "$@" ;;
	service-enable) cmd_service_enable "$@" ;;
	service-disable) cmd_service_disable "$@" ;;
	service-start) cmd_service_start "$@" ;;
	service-stop) cmd_service_stop "$@" ;;
	service-restart) cmd_service_restart "$@" ;;
	*) die "fau-service: unknown command: $cmd" ;;
esac
