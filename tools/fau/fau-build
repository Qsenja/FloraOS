#!/usr/bin/env bash
# fau-build -- builds a package from source on this system, on demand, from a .fis recipe. See fau.md.
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"
# shellcheck source=lib/manifest.sh
source "$SELF_DIR/lib/manifest.sh"
# shellcheck source=lib/alpm.sh
source "$SELF_DIR/lib/alpm.sh"
# shellcheck source=lib/build.sh
source "$SELF_DIR/lib/build.sh"
# shellcheck source=lib/recipes.sh
source "$SELF_DIR/lib/recipes.sh"

csv_words() {
	local item
	for item in $(printf '%s' "${1:-}" | tr ',' ' '); do
		item=$(echo "$item" | xargs)
		[ -n "$item" ] && echo "$item"
	done
}

cmd_build() {
	[ $# -eq 1 ] || die "usage: fau build <name>[=<version>]"
	local arg=$1 name version_req=""
	case "$arg" in
		*=*) name=${arg%%=*}; version_req=${arg#*=} ;;
		*) name=$arg ;;
	esac
	# Freshest recipes first, every build -- a recipe (or a version pin/bump
	# inside one) pushed to FAU_RECIPES_REPO should reach this machine
	# without a new ISO. Non-fatal: recipe_lookup falls back to whatever's
	# already cached from a previous sync, then to the ISO-shipped copy, so
	# a build doesn't hard-fail just because the network's down right now.
	recipes_sync || true
	local recipe; recipe=$(recipe_lookup "$name") \
		|| die "no recipe for '$name' (looked in $FAU_RECIPES_REMOTE_DIR and $FAU_RECIPES_DIR) -- see 'fau build-list'"

	local PKG_SRC_URL="" PKG_SRC_SHA256="" PKG_VERSION="" PKG_DESCRIPTION=""
	local PKG_DEPENDS="" PKG_BUILD_DEPS="" PKG_BIN=""
	# shellcheck source=/dev/null
	source "$recipe"
	[ -n "$PKG_SRC_URL" ] && [ -n "$PKG_SRC_SHA256" ] && [ -n "$PKG_VERSION" ] \
		|| die "$recipe: PKG_SRC_URL/PKG_SRC_SHA256/PKG_VERSION must all be set"
	declare -F recipe_build >/dev/null || die "$recipe: doesn't define recipe_build"

	# A version other than the recipe's own pinned default needs the recipe's
	# opt-in cooperation (recipe_source_for_version) to even know what URL to
	# fetch -- see fau.md. Its output is two lines: the URL, then a pinned
	# sha256 if the recipe author bothered to add one for this exact version,
	# or an empty line if not -- build_fetch_source treats that empty line as
	# "fetch it anyway, just say so loudly" rather than a hard failure.
	if [ -n "$version_req" ] && [ "$version_req" != "$PKG_VERSION" ]; then
		declare -F recipe_source_for_version >/dev/null \
			|| die "$recipe: doesn't support installing a specific version (no recipe_source_for_version defined) -- only $PKG_VERSION is available"
		local src_info; src_info=$(recipe_source_for_version "$version_req") \
			|| die "$recipe: recipe_source_for_version failed for version $version_req"
		PKG_SRC_URL=$(printf '%s\n' "$src_info" | sed -n '1p')
		PKG_SRC_SHA256=$(printf '%s\n' "$src_info" | sed -n '2p')
		[ -n "$PKG_SRC_URL" ] || die "$recipe: recipe_source_for_version didn't return a URL for version $version_req"
		PKG_VERSION=$version_req
	fi

	apps_state_init
	local app_dir="${FAU_APPS_DIR%/}/${name}"
	rm -rf "$app_dir"
	mkdir -p "$app_dir" "$app_dir/config" "$app_dir/cache" "$app_dir/data" "$app_dir/logs"

	local -a depends=(); while IFS= read -r d; do depends+=("$d"); done < <(csv_words "$PKG_DEPENDS")
	local -a build_depends=(); while IFS= read -r d; do build_depends+=("$d"); done < <(csv_words "$PKG_BUILD_DEPS")

	# Deliberately NOT `local` -- the EXIT trap can fire after this function returns (see fau.md).
	sandbox_dir=$(mktemp -d)
	trap 'rm -rf "$sandbox_dir"' EXIT

	# Merging runtime deps into $app_dir, fetching build-only deps into
	# $sandbox_dir, and fetching the recipe's own source are three
	# completely independent operations (different targets, no shared
	# state) -- run them concurrently instead of one after another. Each's
	# own output goes to its own log (interleaving multiple \r-redrawn
	# progress bars directly on the terminal would be unreadable), replayed
	# in full, in order, once all three finish. A background job's exit
	# doesn't fire the EXIT trap set above -- confirmed directly (bash
	# resets trap dispositions for async subshells) -- so this is safe
	# even though the trap is already armed by the time these start.
	local deps_log build_deps_log src_log src_result
	deps_log=$(mktemp); build_deps_log=$(mktemp); src_log=$(mktemp); src_result=$(mktemp)

	local deps_pid="" build_deps_pid=""
	if [ "${#depends[@]}" -gt 0 ]; then
		log "$name: merging ${#depends[@]} runtime dependenc(y/ies) into $app_dir"
		build_merge_depends "$app_dir" "${depends[@]}" > "$deps_log" 2>&1 &
		deps_pid=$!
	fi
	if [ "${#build_depends[@]}" -gt 0 ]; then
		log "$name: fetching ${#build_depends[@]} build-only dependenc(y/ies) into a throwaway sandbox"
		alpm_sandbox_fetch "$sandbox_dir" "${build_depends[@]}" > "$build_deps_log" 2>&1 &
		build_deps_pid=$!
	fi
	log "$name: fetching source ($PKG_SRC_URL)"
	( build_fetch_source "$PKG_SRC_URL" "$PKG_SRC_SHA256" > "$src_result" ) > "$src_log" 2>&1 &
	local src_pid=$!

	# Each stage's own progress bar is stuck inside its redirected log (see
	# comment above) until it's done, so without this the whole thing looks
	# hung for however long the slowest of the three takes -- a full
	# mangowm-sized build-deps closure or a large source tarball can be
	# minutes. Poll all three with `kill -0` instead of blocking `wait`ing on
	# them one at a time, and redraw a single \r status line listing which
	# ones are still outstanding -- one line on this terminal, not three
	# interleaved ones, same constraint the log-redirection above exists for.
	local deps_status=0 build_deps_status=0 src_status=0
	local deps_done="" build_deps_done="" src_done=""
	local spin='-\|/' spin_i=0 start_ts=$SECONDS
	while :; do
		local -a pending=()
		if [ -n "$deps_pid" ] && [ -z "$deps_done" ]; then
			if kill -0 "$deps_pid" 2>/dev/null; then
				pending+=("deps")
			else
				wait "$deps_pid" || deps_status=$?
				deps_done=1
			fi
		fi
		if [ -n "$build_deps_pid" ] && [ -z "$build_deps_done" ]; then
			if kill -0 "$build_deps_pid" 2>/dev/null; then
				pending+=("build-deps")
			else
				wait "$build_deps_pid" || build_deps_status=$?
				build_deps_done=1
			fi
		fi
		if [ -z "$src_done" ]; then
			if kill -0 "$src_pid" 2>/dev/null; then
				pending+=("source")
			else
				wait "$src_pid" || src_status=$?
				src_done=1
			fi
		fi
		[ "${#pending[@]}" -eq 0 ] && break
		spin_i=$(( (spin_i + 1) % 4 ))
		local joined; joined=$(IFS=,; echo "${pending[*]}")
		printf '\r%s: waiting on %s %s (%ds)  ' "$name" "$joined" "${spin:$spin_i:1}" "$((SECONDS - start_ts))" >&2
		sleep 0.2
	done
	printf '\r%*s\r' 70 '' >&2

	[ -s "$deps_log" ] && cat "$deps_log" >&2
	[ -s "$build_deps_log" ] && cat "$build_deps_log" >&2
	[ -s "$src_log" ] && cat "$src_log" >&2
	local tarball; tarball=$(cat "$src_result")
	rm -f "$deps_log" "$build_deps_log" "$src_log" "$src_result"

	[ "$deps_status" -eq 0 ] || die "$name: merging runtime dependencies failed (see log above)"
	[ "$build_deps_status" -eq 0 ] || die "$name: fetching build-only dependencies failed (see log above)"
	[ "$src_status" -eq 0 ] || die "$name: fetching source failed (see log above)"

	local src; src=$(build_extract_source "$name" "$tarball")

	log "$name: building $PKG_VERSION (sandbox: $sandbox_dir)"
	PATH="$sandbox_dir/usr/bin:$PATH" \
		LD_LIBRARY_PATH="$sandbox_dir/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
		PKG_CONFIG_PATH="$sandbox_dir/usr/lib/pkgconfig:$sandbox_dir/usr/share/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}" \
		recipe_build "$src" "$app_dir" "$sandbox_dir"

	local -a bin=(); while IFS= read -r b; do bin+=("$b"); done < <(csv_words "$PKG_BIN")
	{
		echo "name=$name"
		echo "version=$PKG_VERSION"
		echo "description=$PKG_DESCRIPTION"
		echo "depends=$PKG_DEPENDS"
		echo "bin=$PKG_BIN"
	} > "$app_dir/.pkginfo"
	local relbin; for relbin in "${bin[@]}"; do
		app_wrapper_write "$name" "$app_dir" "$relbin"
	done

	json_set "$FAU_APPS_JSON" "$name" "$PKG_VERSION"
	log "built and installed $name $PKG_VERSION into $app_dir"
	case ":$PATH:" in
		*":$FAU_APPS_BIN_DIR:"*) ;;
		*) log "note: $FAU_APPS_BIN_DIR is not on your PATH yet — add it to use $name's commands directly" ;;
	esac
}

cmd_build_list() {
	[ $# -eq 0 ] || die "build-list takes no arguments"
	recipes_sync || true
	recipe_list_names
}

cmd_recipes_update() {
	[ $# -eq 0 ] || die "recipes-update takes no arguments"
	[ -n "${FAU_RECIPES_REPO:-}" ] || die "FAU_RECIPES_REPO is explicitly empty -- recipe syncing is disabled"
	recipes_sync || die "fetching the recipes index from $FAU_RECIPES_REPO failed (see warning above)"
	# Only the index itself is fetched eagerly -- individual .fis files are
	# lazy, one at a time, on first actual use (see lib/recipes.sh) -- so
	# report the index's own count, not how many .fis happen to be cached
	# locally yet (which would misleadingly read 0 right after a sync).
	local n; n=$(wc -l < "$FAU_RECIPES_REMOTE_DIR/recipes.db" 2>/dev/null || echo 0)
	log "synced the recipes index from $FAU_RECIPES_REPO: $n recipe(s) available"
}

cmd=${1:-}; [ $# -ge 1 ] && shift

case "$cmd" in
	build) cmd_build "$@" ;;
	build-list) cmd_build_list "$@" ;;
	recipes-update) cmd_recipes_update "$@" ;;
	*) die "fau-build: unknown command: $cmd" ;;
esac
