#!/usr/bin/env bash
# fau-install -- user-facing package management: install/remove/list isolated apps. See fau.md.
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"
# shellcheck source=lib/manifest.sh
source "$SELF_DIR/lib/manifest.sh"
# shellcheck source=lib/repo.sh
source "$SELF_DIR/lib/repo.sh"
# shellcheck source=lib/alpm.sh
source "$SELF_DIR/lib/alpm.sh"
# shellcheck source=lib/recipes.sh
source "$SELF_DIR/lib/recipes.sh"

app_install_one() {
	local arg=$1 chain=${2:-}
	# name=version -- see fau.md. Only meaningful against the local repo
	# (exact match required, nothing to negotiate) or a recipe's own
	# recipe_source_for_version (same as `fau build name=version`); alpm's
	# real Arch/Artix mirrors only ever carry the latest build of anything,
	# so pinning against that path is a hard error, not silently ignored.
	local name=$arg version_req=""
	case "$arg" in
		*=*) name=${arg%%=*}; version_req=${arg#*=} ;;
	esac
	case ":$chain:" in
		*":$name:"*) die "circular dependency: $chain:$name" ;;
	esac
	local file; file=$(repo_lookup_file "$name")
	if [ -z "$file" ]; then
		if alpm_fallback_available; then
			# app_install_one_alpm decides whether $version_req is even
			# reachable here: a real alpm-resolved name only ever has the
			# latest mirror version and rejects a mismatched one, but a
			# name alpm_resolve can't find at all (dwm, mangowm -- AUR-only)
			# falls through to offer_build -> `fau build name=version`
			# instead, where a version request is actually meaningful. See
			# fau.md and lib/alpm.sh's own app_install_one_alpm.
			app_install_one_alpm "$name" "$version_req"
			return
		fi
		# offer_build's own exit status distinguishes "no recipe exists at
		# all" (1) from "a recipe exists, but declined/no tty to ask on" (2)
		# -- see lib/common.sh. Composing the error here instead of letting
		# offer_build's own || catch it uniformly, so a real recipe that
		# just wasn't built this time doesn't get reported as if $name were
		# entirely unknown to FloraOS.
		local rc=0
		offer_build "$name" "$version_req" || rc=$?
		if [ "$rc" -eq 2 ]; then
			die "$name: not installed (declined to build from source, or no interactive terminal to ask on)"
		elif [ "$rc" -ne 0 ]; then
			die "$name: not in the local repo, no pacman mirrorlist/repo-list available to check the Arch/Artix mirrors, and no fau-build recipe exists for it either"
		fi
	fi

	if [ -n "$version_req" ]; then
		local repo_version; repo_version=$(repo_lookup_version "$name")
		[ "$repo_version" = "$version_req" ] \
			|| die "$name=$version_req: the local repo only has $repo_version -- a local-repo install can't be pinned to an arbitrary version"
	fi

	local existing; existing=$(json_get_version "$FAU_APPS_JSON" "$name")
	local archive="${FAU_REPO_DIR%/}/${file}"

	local depends; depends=$(repo_lookup_depends "$archive")
	if [ -n "${depends:-}" ]; then
		for dep in $(printf '%s' "$depends" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			local dep_name dep_op dep_ver
			IFS=$'\t' read -r dep_name dep_op dep_ver <<< "$(dep_parse "$dep")"
			local dep_installed; dep_installed=$(json_get_version "$FAU_APPS_JSON" "$dep_name")
			if [ -z "$dep_installed" ]; then
				app_install_one "$dep_name" "$chain:$name"
			elif ! version_satisfies "$dep_installed" "$dep_op" "$dep_ver"; then
				log "note: $dep_name $dep_installed is installed but $name needs $dep_name $dep_op$dep_ver -- reinstalling from the repo"
				app_install_one "$dep_name" "$chain:$name"
				dep_installed=$(json_get_version "$FAU_APPS_JSON" "$dep_name")
				version_satisfies "$dep_installed" "$dep_op" "$dep_ver" || \
					die "$name needs $dep_name $dep_op$dep_ver, but the repo only has $dep_installed"
			fi
		done
	fi

	log "installing app $name..."
	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work"
	local version bin; version=$(pkginfo_field "$work/pkginfo" version)
	bin=$(pkginfo_field "$work/pkginfo" bin)

	local app_dir="${FAU_APPS_DIR%/}/${name}"
	rm -rf "$app_dir"
	mkdir -p "$app_dir" "$app_dir/config" "$app_dir/cache" "$app_dir/data" "$app_dir/logs"
	cp -a "$work/files/." "$app_dir"
	cp "$work/pkginfo" "$app_dir/.pkginfo"
	rm -rf "$work"

	if [ -z "${bin:-}" ] && [ -d "$app_dir/bin" ]; then
		bin=$(find "$app_dir/bin" -maxdepth 1 -type f -printf 'bin/%f,' 2>/dev/null)
	fi
	if [ -n "${bin:-}" ]; then
		for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
			relbin=$(echo "$relbin" | xargs)
			[ -z "$relbin" ] && continue
			app_wrapper_write "$name" "$app_dir" "$relbin"
		done
	fi

	json_set "$FAU_APPS_JSON" "$name" "$version"
	if [ -n "$existing" ]; then
		log "upgraded app $name $existing -> $version"
	else
		log "installed app $name $version into $app_dir"
	fi
	case ":$PATH:" in
		*":$FAU_APPS_BIN_DIR:"*) ;;
		*) log "note: $FAU_APPS_BIN_DIR is not on your PATH yet — add it to use $name's commands directly" ;;
	esac
}

cmd_install() {
	[ $# -ge 1 ] || die "install requires at least one package name"
	apps_state_init
	local total=$# i=0
	for name in "$@"; do
		i=$((i + 1))
		[ "$total" -eq 1 ] || log "=== [$i/$total] requested app: $name ==="
		app_install_one "$name"
	done
}

cmd_remove() {
	[ $# -ge 1 ] || die "remove requires at least one package name"
	apps_state_init
	for name in "$@"; do
		[ -n "$(json_get_version "$FAU_APPS_JSON" "$name")" ] || { log "app $name is not installed, skipping"; continue; }
		local app_dir="${FAU_APPS_DIR%/}/${name}"
		local bin; bin=$([ -f "$app_dir/.pkginfo" ] && pkginfo_field "$app_dir/.pkginfo" bin || true)
		if [ -n "${bin:-}" ]; then
			for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
				relbin=$(echo "$relbin" | xargs)
				[ -z "$relbin" ] && continue
				rm -f "$FAU_APPS_BIN_DIR/$(basename "$relbin")"
			done
		fi
		rm -rf "$app_dir"
		json_unset "$FAU_APPS_JSON" "$name"
		log "removed app $name (including its config/cache/data/logs)"
	done
}

cmd_update() {
	apps_state_init
	local -a names=()
	if [ $# -ge 1 ]; then
		names=("$@")
	else
		while IFS= read -r n; do names+=("$n"); done < <(json_list_names "$FAU_APPS_JSON")
	fi
	[ "${#names[@]}" -gt 0 ] || { log "no apps installed, nothing to update"; return 0; }

	# Real network refresh, once, up front -- not per-app -- see
	# alpm_refresh_dbs (lib/alpm.sh) for why a cached/local-shortcut db can
	# never be trusted to answer "is there a newer version" correctly. The
	# recipes repo gets the same treatment, same reasoning: a recipe-built
	# app's own "newer available" check below needs today's PKG_VERSION
	# pin, not whatever was last synced (possibly never, on a fresh install).
	local have_alpm=""
	if alpm_fallback_available; then
		log "refreshing package index from the configured mirrors..."
		alpm_refresh_dbs
		have_alpm=1
	fi
	recipes_sync || true

	local name checked=0 updated=0
	for name in "${names[@]}"; do
		local installed; installed=$(json_get_version "$FAU_APPS_JSON" "$name")
		if [ -z "$installed" ]; then
			log "$name is not installed, skipping"
			continue
		fi
		checked=$((checked + 1))

		local file; file=$(repo_lookup_file "$name")
		if [ -n "$file" ]; then
			local latest; latest=$(repo_lookup_version "$name")
			if [ -n "$latest" ] && [ "$(alpm_vercmp "$latest" "$installed")" -gt 0 ]; then
				app_install_one "$name"
				updated=$((updated + 1))
			else
				log "$name $installed is up to date"
			fi
			continue
		fi

		if [ -n "$have_alpm" ]; then
			local resolved
			resolved=$(alpm_resolve "$name" 2>/dev/null) || resolved=""
			if [ -n "$resolved" ]; then
				local latest; latest=$(printf '%s' "$resolved" | tail -n1 | cut -d"$ALPM_FS" -f3)
				if [ -n "$latest" ] && [ "$(alpm_vercmp "$latest" "$installed")" -gt 0 ]; then
					app_install_one_alpm "$name"
					updated=$((updated + 1))
				else
					log "$name $installed is up to date"
				fi
				continue
			fi
		fi

		# Not in the local repo, and either alpm has nothing by this name or
		# no mirrorlist/repo-list is configured at all -- the only other
		# source fau ever installs from is a `fau build` recipe (mangowm and
		# anything else AUR-only). A recipe's own PKG_VERSION is a static
		# pin an actual person bumps by hand, not something to resolve
		# against a live index -- "newer available" here just means "the
		# recipe shipped on this system is now pinned ahead of what's
		# installed", so rebuild against that pin instead of only pointing
		# the user at the command themselves. See fau.md.
		local recipe; recipe=$(recipe_lookup "$name") || recipe=""
		if [ -n "$recipe" ]; then
			# Subshell: sourcing a recipe defines recipe_build/PKG_* in
			# whatever sources it, and this loop sources a different
			# recipe every iteration -- a subshell via $(...) throws that
			# away on exit instead of leaking it into the next iteration.
			local recipe_version
			recipe_version=$(source "$recipe"; echo "${PKG_VERSION:-}") || recipe_version=""
			if [ -n "$recipe_version" ] && [ "$(alpm_vercmp "$recipe_version" "$installed")" -gt 0 ]; then
				log "$name: recipe pinned to $recipe_version (installed: $installed) -- rebuilding"
				if "$SELF_DIR/fau-build" build "$name"; then
					updated=$((updated + 1))
				else
					log "$name: rebuild failed, skipping"
				fi
			else
				log "$name $installed is up to date (built from a recipe, still pinned to $recipe_version)"
			fi
			continue
		fi

		log "$name: not found in the local repo, the configured mirrors, or as a build recipe -- skipping"
	done
	log "checked $checked app(s), updated $updated"
}

cmd_list() {
	# Base system packages (FAU_SYSTEM_JSON, tracked by fau bootstrap at
	# ISO-build time) plus isolated apps (FAU_APPS_JSON) -- everything
	# actually on the system, not just the isolated-apps half of it. Used
	# to be apps only, which made "fau list" and fastfetch's own custom
	# "Packages: N (fau)" module (assets/fastfetch-config.jsonc, which
	# used to separately sum `fau bootstrap-list` + `fau list` for exactly
	# this reason) visibly disagree -- fastfetch's own module is simpler
	# now too, just `fau list | wc -l`, no separate bootstrap-list call.
	apps_state_init
	local n
	for n in $(json_list_names "$FAU_SYSTEM_JSON"); do
		printf '%s %s\n' "$n" "$(json_get_version "$FAU_SYSTEM_JSON" "$n")"
	done
	for n in $(json_list_names "$FAU_APPS_JSON"); do
		printf '%s %s\n' "$n" "$(json_get_version "$FAU_APPS_JSON" "$n")"
	done
}

cmd=${1:-}; [ $# -ge 1 ] && shift

case "$cmd" in
	install) cmd_install "$@" ;;
	remove) cmd_remove "$@" ;;
	update) cmd_update "$@" ;;
	list) cmd_list "$@" ;;
	*) die "fau-install: unknown command: $cmd" ;;
esac
