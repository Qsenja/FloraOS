#!/usr/bin/env bash
# fau-install -- user-facing package management: install/remove/list. Each
# app lives entirely under FAU_APPS_DIR/<name>/: its own files, plus
# config/cache/data/logs subdirs. Wrapper scripts in FAU_APPS_BIN_DIR (put
# that on PATH) set HOME/XDG_*_HOME to redirect the app into its own
# directory before exec'ing the real binary -- works for any app that
# follows the XDG Base Directory spec (most modern Linux software does).
# Apps that hardcode absolute paths won't cooperate; that's a known limit,
# not a bug. Called by the `fau` dispatcher; fully runnable standalone too.
set -euo pipefail

# readlink -f before dirname: see tools/fau/fau's own comment on this --
# only that file is symlinked today (/usr/bin/fau), but the fix is free.
SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"
# shellcheck source=lib/manifest.sh
source "$SELF_DIR/lib/manifest.sh"
# shellcheck source=lib/repo.sh
source "$SELF_DIR/lib/repo.sh"
# shellcheck source=lib/alpm.sh
# alpm.sh's own app_install_one_alpm calls app_wrapper_write, defined below
# in this file -- fine, since bash only resolves a function call at the
# moment it actually runs, not at source time, and by the time
# app_install_one (also below) calls into alpm.sh this file's own
# app_wrapper_write is already defined in the same shell.
source "$SELF_DIR/lib/alpm.sh"

app_wrapper_write() {
	# app_wrapper_write <name> <app-dir> <relbin>
	local name=$1 app_dir=$2 relbin=$3
	local cmd_name; cmd_name=$(basename "$relbin")
	local wrapper="$FAU_APPS_BIN_DIR/$cmd_name"
	# Flat usr/lib:lib covers most packages, but some (perl, for one) ship
	# their real runtime .so nested well below that -- perl's own
	# libperl.so lives at usr/lib/perl5/<ver>/core_perl/CORE/libperl.so,
	# not directly under usr/lib/, so cowsay (a perl script) failed at
	# runtime with "libperl.so: cannot open shared object file" despite
	# installing fine. Computed once here (at wrapper-write time, not on
	# every invocation) by finding every directory under the app that
	# actually contains a shared library, so this covers that case and any
	# other package with a similarly nested private lib directory.
	local nested_libdirs; nested_libdirs=$(find "$app_dir" -iname '*.so*' -exec dirname {} \; 2>/dev/null | sort -u | tr '\n' ':')
	local app_libdir="$app_dir/usr/lib:$app_dir/lib:${nested_libdirs%:}"
	app_libdir=${app_libdir%:}
	# Same problem, one level up: perl itself is compiled with @INC pointing
	# at the real /usr/lib/perl5/..., not this app's own isolated copy, so a
	# perl script here (cowsay, for one) found libperl.so fine but then
	# failed with "Can't locate Cwd.pm in @INC" -- Cwd.pm existed, just under
	# $app_dir, which perl's compiled-in search path never looks at. PERL5LIB
	# is perl's own supported override for exactly this (like
	# LD_LIBRARY_PATH, but for .pm modules instead of .so libraries) -- no
	# need to patch perl or chroot anything.
	local perl5lib; perl5lib=$(find "$app_dir" -iname '*.pm' -exec dirname {} \; 2>/dev/null | sort -u | tr '\n' ':')
	perl5lib=${perl5lib%:}
	cat > "$wrapper" <<-EOF
	#!/bin/sh
	export HOME="$app_dir"
	export XDG_CONFIG_HOME="$app_dir/config"
	export XDG_CACHE_HOME="$app_dir/cache"
	export XDG_DATA_HOME="$app_dir/data"
	export XDG_STATE_HOME="$app_dir/logs"
	export LD_LIBRARY_PATH="$app_libdir\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}"
	export PATH="$app_dir/usr/bin:$app_dir/bin\${PATH:+:\$PATH}"
	${perl5lib:+export PERL5LIB="$perl5lib\${PERL5LIB:+:\$PERL5LIB}"}
	exec "$app_dir/$relbin" "\$@"
	EOF
	chmod 755 "$wrapper"
}

app_install_one() {
	# app_install_one <name> [ancestor-chain] -- see fau-bootstrap's own
	# install_one comment for why the chain is a plain argument, not a
	# global.
	local name=$1 chain=${2:-}
	case ":$chain:" in
		*":$name:"*) die "circular dependency: $chain:$name" ;;
	esac
	local file; file=$(repo_lookup_file "$name")
	if [ -z "$file" ]; then
		if alpm_fallback_available; then
			app_install_one_alpm "$name"
			return
		fi
		die "package not found in repo: $name (and no pacman mirrorlist/repo-list available to fall back to)"
	fi

	local existing; existing=$(json_get_version "$FAU_APPS_JSON" "$name")
	local archive="${FAU_REPO_DIR%/}/${file}"

	local depends; depends=$(repo_lookup_depends "$archive")
	if [ -n "${depends:-}" ]; then
		for dep in $(printf '%s' "$depends" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			local dep_name dep_op dep_ver
			IFS=$'\t' read -r dep_name dep_op dep_ver <<< "$(dep_parse "$dep")"
			local dep_installed; dep_installed=$(json_get_version "$FAU_APPS_JSON" "$dep_name")
			if [ -z "$dep_installed" ]; then
				app_install_one "$dep_name" "$chain:$name"
			elif ! version_satisfies "$dep_installed" "$dep_op" "$dep_ver"; then
				log "note: $dep_name $dep_installed is installed but $name needs $dep_name $dep_op$dep_ver -- reinstalling from the repo"
				app_install_one "$dep_name" "$chain:$name"
				dep_installed=$(json_get_version "$FAU_APPS_JSON" "$dep_name")
				version_satisfies "$dep_installed" "$dep_op" "$dep_ver" || \
					die "$name needs $dep_name $dep_op$dep_ver, but the repo only has $dep_installed"
			fi
		done
	fi

	log "installing app $name..."
	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work"
	local version bin; version=$(pkginfo_field "$work/pkginfo" version)
	bin=$(pkginfo_field "$work/pkginfo" bin)

	local app_dir="${FAU_APPS_DIR%/}/${name}"
	rm -rf "$app_dir"
	mkdir -p "$app_dir" "$app_dir/config" "$app_dir/cache" "$app_dir/data" "$app_dir/logs"
	cp -a "$work/files/." "$app_dir"
	cp "$work/pkginfo" "$app_dir/.pkginfo"
	rm -rf "$work"

	if [ -z "${bin:-}" ] && [ -d "$app_dir/bin" ]; then
		bin=$(find "$app_dir/bin" -maxdepth 1 -type f -printf 'bin/%f,' 2>/dev/null)
	fi
	if [ -n "${bin:-}" ]; then
		for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
			relbin=$(echo "$relbin" | xargs)
			[ -z "$relbin" ] && continue
			app_wrapper_write "$name" "$app_dir" "$relbin"
		done
	fi

	json_set "$FAU_APPS_JSON" "$name" "$version"
	if [ -n "$existing" ]; then
		log "upgraded app $name $existing -> $version"
	else
		log "installed app $name $version into $app_dir"
	fi
	case ":$PATH:" in
		*":$FAU_APPS_BIN_DIR:"*) ;;
		*) log "note: $FAU_APPS_BIN_DIR is not on your PATH yet — add it to use $name's commands directly" ;;
	esac
}

cmd_install() {
	[ $# -ge 1 ] || die "install requires at least one package name"
	apps_state_init
	local total=$# i=0
	for name in "$@"; do
		i=$((i + 1))
		[ "$total" -eq 1 ] || log "=== [$i/$total] requested app: $name ==="
		app_install_one "$name"
	done
}

cmd_remove() {
	[ $# -ge 1 ] || die "remove requires at least one package name"
	apps_state_init
	for name in "$@"; do
		[ -n "$(json_get_version "$FAU_APPS_JSON" "$name")" ] || { log "app $name is not installed, skipping"; continue; }
		local app_dir="${FAU_APPS_DIR%/}/${name}"
		local bin; bin=$([ -f "$app_dir/.pkginfo" ] && pkginfo_field "$app_dir/.pkginfo" bin || true)
		if [ -n "${bin:-}" ]; then
			for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
				relbin=$(echo "$relbin" | xargs)
				[ -z "$relbin" ] && continue
				rm -f "$FAU_APPS_BIN_DIR/$(basename "$relbin")"
			done
		fi
		rm -rf "$app_dir"
		json_unset "$FAU_APPS_JSON" "$name"
		log "removed app $name (including its config/cache/data/logs)"
	done
}

cmd_list() {
	apps_state_init
	for n in $(json_list_names "$FAU_APPS_JSON"); do
		printf '%s %s\n' "$n" "$(json_get_version "$FAU_APPS_JSON" "$n")"
	done
}

cmd=${1:-}; [ $# -ge 1 ] && shift

case "$cmd" in
	install) cmd_install "$@" ;;
	remove) cmd_remove "$@" ;;
	list) cmd_list "$@" ;;
	*) die "fau-install: unknown command: $cmd" ;;
esac
