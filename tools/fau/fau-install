#!/usr/bin/env bash
# fau-install -- user-facing package management: install/remove/list isolated apps. See fau.md.
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"
# shellcheck source=lib/manifest.sh
source "$SELF_DIR/lib/manifest.sh"
# shellcheck source=lib/repo.sh
source "$SELF_DIR/lib/repo.sh"
# shellcheck source=lib/alpm.sh
source "$SELF_DIR/lib/alpm.sh"
# shellcheck source=lib/recipes.sh
source "$SELF_DIR/lib/recipes.sh"
# shellcheck source=lib/selfupdate.sh
source "$SELF_DIR/lib/selfupdate.sh"

app_install_one() {
	local arg=$1 chain=${2:-}
	# name=version -- see fau.md. Only meaningful against the local repo
	# (exact match required, nothing to negotiate) or a recipe's own
	# recipe_source_for_version (same as `fau build name=version`); alpm's
	# real Arch/Artix mirrors only ever carry the latest build of anything,
	# so pinning against that path is a hard error, not silently ignored.
	local name=$arg version_req=""
	case "$arg" in
		*=*) name=${arg%%=*}; version_req=${arg#*=} ;;
	esac
	case ":$chain:" in
		*":$name:"*) die "circular dependency: $chain:$name" ;;
	esac
	local file; file=$(repo_lookup_file "$name")
	if [ -z "$file" ]; then
		if alpm_fallback_available; then
			# app_install_one_alpm decides whether $version_req is even
			# reachable here: a real alpm-resolved name only ever has the
			# latest mirror version and rejects a mismatched one, but a
			# name alpm_resolve can't find at all (dwm, mangowm -- AUR-only)
			# falls through to offer_build -> `fau build name=version`
			# instead, where a version request is actually meaningful. See
			# fau.md and lib/alpm.sh's own app_install_one_alpm.
			app_install_one_alpm "$name" "$version_req"
			return
		fi
		# offer_build's own exit status distinguishes "no recipe exists at
		# all" (1) from "a recipe exists, but declined/no tty to ask on" (2)
		# -- see lib/common.sh. Composing the error here instead of letting
		# offer_build's own || catch it uniformly, so a real recipe that
		# just wasn't built this time doesn't get reported as if $name were
		# entirely unknown to FloraOS.
		local rc=0
		offer_build "$name" "$version_req" || rc=$?
		if [ "$rc" -eq 2 ]; then
			die "$name: not installed (declined to build from source, or no interactive terminal to ask on)"
		elif [ "$rc" -ne 0 ]; then
			die "$name: not in the local repo, no pacman mirrorlist/repo-list available to check the Arch/Artix mirrors, and no fau-build recipe exists for it either"
		fi
	fi

	if [ -n "$version_req" ]; then
		local repo_version; repo_version=$(repo_lookup_version "$name")
		[ "$repo_version" = "$version_req" ] \
			|| die "$name=$version_req: the local repo only has $repo_version, can't pin a local-repo install to an arbitrary version"
	fi

	local existing; existing=$(json_get_version "$FAU_APPS_JSON" "$name")
	local archive="${FAU_REPO_DIR%/}/${file}"

	local depends; depends=$(repo_lookup_depends "$archive")
	if [ -n "${depends:-}" ]; then
		for dep in $(printf '%s' "$depends" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			local dep_name dep_op dep_ver
			IFS=$'\t' read -r dep_name dep_op dep_ver <<< "$(dep_parse "$dep")"
			local dep_installed; dep_installed=$(json_get_version "$FAU_APPS_JSON" "$dep_name")
			if [ -z "$dep_installed" ]; then
				app_install_one "$dep_name" "$chain:$name"
			elif ! version_satisfies "$dep_installed" "$dep_op" "$dep_ver"; then
				log "note: $dep_name $dep_installed is installed but $name needs $dep_name $dep_op$dep_ver, reinstalling from the repo"
				app_install_one "$dep_name" "$chain:$name"
				dep_installed=$(json_get_version "$FAU_APPS_JSON" "$dep_name")
				version_satisfies "$dep_installed" "$dep_op" "$dep_ver" || \
					die "$name needs $dep_name $dep_op$dep_ver, but the repo only has $dep_installed"
			fi
		done
	fi

	log "installing app $name..."
	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work"
	local version bin; version=$(pkginfo_field "$work/pkginfo" version)
	bin=$(pkginfo_field "$work/pkginfo" bin)

	local app_dir="${FAU_APPS_DIR%/}/${name}"
	rm -rf "$app_dir"
	mkdir -p "$app_dir" "$app_dir/config" "$app_dir/cache" "$app_dir/data" "$app_dir/logs"
	cp -a "$work/files/." "$app_dir"
	cp "$work/pkginfo" "$app_dir/.pkginfo"
	rm -rf "$work"

	if [ -z "${bin:-}" ] && [ -d "$app_dir/bin" ]; then
		bin=$(find "$app_dir/bin" -maxdepth 1 -type f -printf 'bin/%f,' 2>/dev/null)
	fi
	if [ -n "${bin:-}" ]; then
		for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
			relbin=$(echo "$relbin" | xargs)
			[ -z "$relbin" ] && continue
			app_wrapper_write "$name" "$app_dir" "$relbin"
		done
	fi
	app_desktop_merge "$app_dir"

	json_set "$FAU_APPS_JSON" "$name" "$version"
	if [ -n "$existing" ]; then
		log "upgraded app $name $existing -> $version"
	else
		log "installed app $name $version into $app_dir"
	fi
	case ":$PATH:" in
		*":$FAU_APPS_BIN_DIR:"*) ;;
		*) log "note: $FAU_APPS_BIN_DIR is not on your PATH yet — add it to use $name's commands directly" ;;
	esac
}

cmd_install() {
	[ $# -ge 1 ] || die "install requires at least one package name"
	apps_state_init
	local total=$# i=0
	for name in "$@"; do
		i=$((i + 1))
		[ "$total" -eq 1 ] || log "=== [$i/$total] requested app: $name ==="
		app_install_one "$name"
	done
}

cmd_remove() {
	[ $# -ge 1 ] || die "remove requires at least one package name"
	apps_state_init
	for name in "$@"; do
		[ -n "$(json_get_version "$FAU_APPS_JSON" "$name")" ] || { log "app $name is not installed, skipping"; continue; }
		local app_dir="${FAU_APPS_DIR%/}/${name}"
		local bin; bin=$([ -f "$app_dir/.pkginfo" ] && pkginfo_field "$app_dir/.pkginfo" bin || true)
		if [ -n "${bin:-}" ]; then
			for relbin in $(printf '%s' "$bin" | tr ',' ' '); do
				relbin=$(echo "$relbin" | xargs)
				[ -z "$relbin" ] && continue
				rm -f "$FAU_APPS_BIN_DIR/$(basename "$relbin")"
			done
		fi
		# Mirrors app_desktop_merge (lib/common.sh): remove whatever this
		# app's own .desktop files put into the shared FAU_APPS_DIR/.data
		# tree, by the same source list, before app_dir itself is gone.
		if [ -d "$app_dir/usr/share/applications" ]; then
			for f in "$app_dir/usr/share/applications"/*.desktop; do
				[ -f "$f" ] || continue
				rm -f "${FAU_APPS_DIR%/}/.data/applications/$(basename "$f")"
			done
		fi
		rm -rf "$app_dir"
		json_unset "$FAU_APPS_JSON" "$name"
		log "removed app $name (including its config/cache/data/logs)"
	done
}

cmd_update() {
	apps_state_init
	state_init

	# Unconditional, once per invocation, before any checking/updating --
	# see fau.md. fau backup itself refuses a non-block-device root (the
	# live RAM image) with its own clear message; that's an expected,
	# non-fatal outcome here, not a fau-update failure, so its exit status
	# is never allowed to abort the update itself.
	local backup_rc=0
	"$SELF_DIR/fau-backup" backup "pre-update-$(date -u +%Y%m%dT%H%M%SZ)" || backup_rc=$?
	[ "$backup_rc" -eq 0 ] || log "continuing without a pre-update backup (see above)"

	local -a app_names=() sys_names=()
	if [ $# -ge 1 ]; then
		local n
		for n in "$@"; do
			if [ -n "$(json_get_version "$FAU_APPS_JSON" "$n")" ]; then
				app_names+=("$n")
			elif [ -n "$(system_get_version "$n")" ]; then
				sys_names+=("$n")
			else
				log "$n: not installed, skipping"
			fi
		done
	else
		while IFS= read -r n; do app_names+=("$n"); done < <(json_list_names "$FAU_APPS_JSON")
		while IFS= read -r n; do sys_names+=("$n"); done < <(system_list_names)
	fi
	[ "${#app_names[@]}" -gt 0 ] || [ "${#sys_names[@]}" -gt 0 ] \
		|| { log "nothing installed, nothing to update"; return 0; }

	# Real network refresh, once, up front, not per-app/package: a
	# cached/local-shortcut db can't be trusted to answer "is there a
	# newer version" correctly (see alpm_refresh_dbs, lib/alpm.sh).
	local have_alpm=""
	if alpm_fallback_available; then
		log "refreshing package databanks from the configured mirrors..."
		alpm_refresh_dbs
		have_alpm=1
	fi
	recipes_sync || true

	# up_to_date/pinned_names are printed as one summary line each below,
	# not one line per package: with 20-30 base packages typically pinned
	# from source, a line each was most of this command's own output.
	local name checked=0 updated=0
	local -a up_to_date=()
	for name in "${app_names[@]}"; do
		local installed; installed=$(json_get_version "$FAU_APPS_JSON" "$name")
		if [ -z "$installed" ]; then
			log "$name: not installed, skipping"
			continue
		fi
		checked=$((checked + 1))

		local file; file=$(repo_lookup_file "$name")
		if [ -n "$file" ]; then
			local latest; latest=$(repo_lookup_version "$name")
			if [ -n "$latest" ] && [ "$(alpm_vercmp "$latest" "$installed")" -gt 0 ]; then
				app_install_one "$name"
				updated=$((updated + 1))
			else
				up_to_date+=("$name")
			fi
			continue
		fi

		if [ -n "$have_alpm" ]; then
			local resolved
			resolved=$(alpm_resolve "$name" 2>/dev/null) || resolved=""
			if [ -n "$resolved" ]; then
				local latest; latest=$(printf '%s' "$resolved" | tail -n1 | cut -d"$ALPM_FS" -f3)
				if [ -n "$latest" ] && [ "$(alpm_vercmp "$latest" "$installed")" -gt 0 ]; then
					app_install_one_alpm "$name"
					updated=$((updated + 1))
				else
					up_to_date+=("$name")
				fi
				continue
			fi
		fi

		# Not in the local repo, and either alpm has nothing by this name
		# or no mirrorlist/repo-list is configured: the only other source
		# fau installs from is a `fau build` recipe (mangowm and anything
		# else AUR-only). A recipe's own PKG_VERSION is a static pin
		# bumped by hand, not resolved against a live index: "newer
		# available" means the recipe shipped here is now pinned ahead of
		# what's installed, so rebuild against that pin. See fau.md.
		local recipe; recipe=$(recipe_lookup "$name") || recipe=""
		if [ -n "$recipe" ]; then
			# Subshell: sourcing a recipe defines recipe_build/PKG_* in
			# whatever sources it, and a different recipe is sourced each
			# iteration; $(...) discards that on exit instead of leaking
			# into the next one.
			local recipe_version
			recipe_version=$(source "$recipe"; echo "${PKG_VERSION:-}") || recipe_version=""
			if [ -n "$recipe_version" ] && [ "$(alpm_vercmp "$recipe_version" "$installed")" -gt 0 ]; then
				log "$name: rebuilding, recipe pinned to $recipe_version (was $installed)"
				if "$SELF_DIR/fau-build" build "$name"; then
					updated=$((updated + 1))
				else
					log "$name: rebuild failed, skipping"
				fi
			else
				up_to_date+=("$name")
			fi
			continue
		fi

		log "$name: not found in the local repo, the mirrors, or as a build recipe, skipping"
	done
	[ "${#up_to_date[@]}" -eq 0 ] || log "up to date: ${up_to_date[*]}"

	# System packages: MANDATORY_ORDER/EXTRA_PACKAGES packages (tracked in
	# source-built-packages, written by build-rootfs.sh) get no newer
	# version from the alpm fallback: re-fetching them that way would
	# silently replace FloraOS's own from-source build with Arch's
	# binary, exactly the bug fau.md documents as already found and fixed
	# once. They're still updatable in place if a *system recipe* now
	# exists for them (fau-recipes' system/ namespace, built on this
	# machine via `fau bootstrap-build`, never via alpm), checked below
	# before falling back to "rebuild the ISO." Everything else in
	# system.json (libgcc, fontconfig, dbus, ... see build-rootfs.sh) is
	# alpm-fallback eligible as before. See fau.md.
	local -A source_built=()
	local source_built_list="${FAU_ROOT%/}/etc/fau/source-built-packages"
	if [ -f "$source_built_list" ]; then
		local sn
		while IFS= read -r sn; do [ -n "$sn" ] && source_built[$sn]=1; done < "$source_built_list"
	fi
	system_recipes_sync || true

	local sys_checked=0 sys_updated=0 sys_pinned=0
	local -a sys_up_to_date=() pinned_names=()
	for name in "${sys_names[@]}"; do
		local installed; installed=$(system_get_version "$name")
		if [ -z "$installed" ]; then
			log "$name: not an installed system package, skipping"
			continue
		fi
		if [ -n "${source_built[$name]:-}" ]; then
			local sysrecipe; sysrecipe=$(system_recipe_lookup "$name") || sysrecipe=""
			if [ -n "$sysrecipe" ]; then
				local sysrecipe_version
				sysrecipe_version=$(source "$sysrecipe"; echo "${PKG_VERSION:-}") || sysrecipe_version=""
				if [ -n "$sysrecipe_version" ] && [ "$(alpm_vercmp "$sysrecipe_version" "$installed")" -gt 0 ]; then
					log "$name: rebuilding from source, pinned to $sysrecipe_version (was $installed)"
					if "$SELF_DIR/fau-bootstrap" bootstrap-build "$name"; then
						sys_checked=$((sys_checked + 1))
						sys_updated=$((sys_updated + 1))
					else
						log "$name: rebuild failed, skipping"
						sys_pinned=$((sys_pinned + 1))
					fi
					continue
				fi
				sys_up_to_date+=("$name")
				sys_checked=$((sys_checked + 1))
				continue
			fi
			sys_pinned=$((sys_pinned + 1))
			pinned_names+=("$name")
			continue
		fi
		sys_checked=$((sys_checked + 1))

		if [ -n "$have_alpm" ]; then
			local resolved
			resolved=$(alpm_resolve "$name" 2>/dev/null) || resolved=""
			if [ -n "$resolved" ]; then
				local latest; latest=$(printf '%s' "$resolved" | tail -n1 | cut -d"$ALPM_FS" -f3)
				if [ -n "$latest" ] && [ "$(alpm_vercmp "$latest" "$installed")" -gt 0 ]; then
					install_one_alpm "$name"
					sys_updated=$((sys_updated + 1))
				else
					sys_up_to_date+=("$name")
				fi
				continue
			fi
		fi

		log "$name: not found on the configured mirrors, skipping"
	done
	[ "${#sys_up_to_date[@]}" -eq 0 ] || log "up to date: ${sys_up_to_date[*]}"
	[ "${#pinned_names[@]}" -eq 0 ] || log "pinned from source, rebuild the ISO to update: ${pinned_names[*]}"

	log "checked $checked app(s), updated $updated; checked $sys_checked system package(s) ($sys_pinned pinned from source), updated $sys_updated"

	# FloraOS's own files (fau's dispatcher/subtools/lib, the 5 C tools,
	# floragrub-cfg): per-file, keyed on each one's own git blob sha, not
	# bundled into one version/one rebuild. Safe to run at any point
	# here: a changed tools/fau/fau-install would replace this very file,
	# but via a staged atomic `mv`, which only repoints the path to a new
	# inode; this already-running process keeps reading its own open
	# copy of the old file until it exits. See fau.md.
	if floraos_selfupdate_sweep; then
		if [ "$FLORAOS_SELFUPDATE_CHANGED" -gt 0 ]; then
			log "fau itself: $FLORAOS_SELFUPDATE_CHANGED file(s) updated from $FAU_SELFUPDATE_REPO"
		else
			log "fau itself: up to date"
		fi
	fi
}

cmd_list() {
	# Base system packages (FAU_SYSTEM_JSON, tracked by fau bootstrap at
	# ISO-build time) plus isolated apps (FAU_APPS_JSON) -- everything
	# actually on the system, not just the isolated-apps half of it. Used
	# to be apps only, which made "fau list" and fastfetch's own custom
	# "Packages: N (fau)" module (assets/fastfetch-config.jsonc, which
	# used to separately sum `fau bootstrap-list` + `fau list` for exactly
	# this reason) visibly disagree -- fastfetch's own module is simpler
	# now too, just `fau list | wc -l`, no separate bootstrap-list call.
	apps_state_init
	local n
	for n in $(json_list_names "$FAU_SYSTEM_JSON"); do
		printf '%s %s\n' "$n" "$(json_get_version "$FAU_SYSTEM_JSON" "$n")"
	done
	for n in $(json_list_names "$FAU_APPS_JSON"); do
		printf '%s %s\n' "$n" "$(json_get_version "$FAU_APPS_JSON" "$n")"
	done
}

cmd=${1:-}; [ $# -ge 1 ] && shift

case "$cmd" in
	install) cmd_install "$@" ;;
	remove) cmd_remove "$@" ;;
	update) cmd_update "$@" ;;
	list) cmd_list "$@" ;;
	*) die "fau-install: unknown command: $cmd" ;;
esac
