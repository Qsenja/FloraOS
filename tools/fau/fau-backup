#!/usr/bin/env bash
# fau-backup -- full-root btrfs snapshot/restore via GRUB menu entries. See fau.md.
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"

backup_name_check() {
	# ".." is rejected explicitly: its charset alone would pass the check below.
	local name=$1
	[ -n "$name" ] || die "backup name required"
	case "$name" in *..*) die "backup name can't contain '..'" ;; esac
	printf '%s' "$name" | grep -Eq '^[A-Za-z0-9._-]+$' \
		|| die "backup name must match ^[A-Za-z0-9._-]+\$ (it becomes a GRUB menu entry and a filesystem path segment)"
}

# findmnt's SOURCE column suffixes a subvolume mount, e.g. "/dev/sda1[/@]"; stripped below.
root_device() {
	local device; device=$(findmnt -n -o SOURCE /) || die "can't find the device mounted at / (findmnt failed)"
	printf '%s' "${device%%\[*}"
}

# Callback runs in a subshell so a die() inside it still lets the unmount below run.
backup_with_toplevel() {
	local fn=$1; shift
	local device; device=$(root_device)
	[ -b "$device" ] || die "$device (source of /) isn't a block device -- fau backup only supports a real disk install"
	local uuid; uuid=$(blkid -s UUID -o value "$device") || die "blkid couldn't read $device's UUID"
	# /dev/shm, not mktemp -d's default under /tmp: /tmp can be the read-only root (see fau.md).
	local tmp; tmp=$(mktemp -d -p /dev/shm)
	mount -o subvolid=5 "$device" "$tmp" || { rmdir "$tmp"; die "mount -o subvolid=5 $device failed"; }
	local rc=0
	( "$fn" "$tmp" "$device" "$uuid" "$@" ) || rc=$?
	umount "$tmp" 2>/dev/null || true
	rmdir "$tmp" 2>/dev/null || true
	return $rc
}

backup_regen_grub() {
	# Called after backup_with_toplevel has unmounted $tmp: floragrub-cfg does its own subvolid=5 mount.
	floragrub-cfg "$1" "$2" /boot/grub/grub.cfg
}

_backup_do() {
	local tmp=$1 name=$4
	[ -e "$tmp/@snapshots/$name" ] && die "backup '$name' already exists (see 'fau backup-list')"
	mkdir -p "$tmp/@snapshots"
	btrfs subvolume snapshot -r / "$tmp/@snapshots/$name" || die "btrfs subvolume snapshot failed"
	return 0
}

cmd_backup() {
	[ $# -eq 1 ] || die "usage: fau backup <name>"
	backup_name_check "$1"
	backup_with_toplevel _backup_do "$1"
	local device; device=$(root_device)
	local uuid; uuid=$(blkid -s UUID -o value "$device") || die "blkid couldn't read $device's UUID"
	backup_regen_grub "$device" "$uuid"
	log "backup '$1' created -- pick \"FloraOS (backup: $1)\" at the GRUB menu to boot into it"
}

_backup_list_do() {
	local tmp=$1
	[ -d "$tmp/@snapshots" ] || return 0
	( cd "$tmp/@snapshots" && ls -1t -- ) 2>/dev/null
}

cmd_backup_list() {
	[ $# -eq 0 ] || die "backup-list takes no arguments"
	local out; out=$(backup_with_toplevel _backup_list_do)
	if [ -z "$out" ]; then
		log "no backups yet (see 'fau backup <name>')"
	else
		printf '%s\n' "$out"
	fi
}

_backup_remove_do() {
	local tmp=$1 name=$4
	[ -e "$tmp/@snapshots/$name" ] || die "no such backup: $name (see 'fau backup-list')"
	btrfs subvolume delete "$tmp/@snapshots/$name" || die "btrfs subvolume delete failed"
}

cmd_backup_remove() {
	[ $# -eq 1 ] || die "usage: fau backup-remove <name>"
	backup_name_check "$1"
	backup_with_toplevel _backup_remove_do "$1"
	local device; device=$(root_device)
	local uuid; uuid=$(blkid -s UUID -o value "$device") || die "blkid couldn't read $device's UUID"
	backup_regen_grub "$device" "$uuid"
	log "backup '$1' removed"
}

_backup_restore_do() {
	local tmp=$1 name=$4
	[ -e "$tmp/@snapshots/$name" ] || die "no such backup: $name (see 'fau backup-list')"
	local ts; ts=$(date -u +%Y%m%dT%H%M%SZ)
	# Not atomic (no renameat2 RENAME_EXCHANGE available); see fau.md for the crash window this narrows.
	btrfs property set "$tmp/@snapshots/$name" ro false || die "clearing the snapshot's read-only property failed -- @ is untouched, nothing to repair, just re-run 'fau backup-restore $name'"
	mv "$tmp/@" "$tmp/@pre-restore-$name-$ts" || die "renaming the current @ aside failed"
	mv "$tmp/@snapshots/$name" "$tmp/@" \
		|| die "promoting $name to @ failed -- @ is currently MISSING. The GRUB menu's default entry (subvol=@) won't boot until this is fixed, but \"FloraOS (backup: $name)\" (subvol=@snapshots/$name, untouched by the failed rename) still will -- boot that, then run 'fau backup-repair $name' from there. Or fix by hand: mv @pre-restore-$name-$ts back to @"
}

cmd_backup_restore() {
	[ $# -eq 1 ] || die "usage: fau backup-restore <name>"
	backup_name_check "$1"
	backup_with_toplevel _backup_restore_do "$1"
	local device; device=$(root_device)
	local uuid; uuid=$(blkid -s UUID -o value "$device") || die "blkid couldn't read $device's UUID"
	backup_regen_grub "$device" "$uuid"
	log "restored '$1' to @ (previous root kept as @pre-restore-$1-*)"
	log "this session is still running on the OLD root -- reboot to actually boot the restored system"
}

_backup_repair_do() {
	local tmp=$1 name=$4
	# Only completes one specific interrupted-restore state; anything else is refused (see fau.md).
	[ ! -e "$tmp/@" ] || die "@ already exists -- nothing to repair. If you meant to restore '$name' fresh, use 'fau backup-restore $name' instead"
	[ -e "$tmp/@snapshots/$name" ] \
		|| die "@ is missing but @snapshots/$name doesn't exist either -- this isn't the interrupted-restore state backup-repair knows how to fix. Recover manually (see docs/TODO.md's fau-backup entry): the previous root should still be at some @pre-restore-$name-<timestamp>"
	log "@ is missing and @snapshots/$name still exists -- completing the interrupted 'backup-restore $name'"
	btrfs property set "$tmp/@snapshots/$name" ro false || die "clearing the snapshot's read-only property failed -- retry 'fau backup-repair $name'"
	mv "$tmp/@snapshots/$name" "$tmp/@" || die "promoting $name to @ failed -- retry 'fau backup-repair $name'"
}

cmd_backup_repair() {
	[ $# -eq 1 ] || die "usage: fau backup-repair <name>  -- run after booting the \"FloraOS (backup: <name>)\" GRUB entry when a crash interrupted 'backup-restore <name>' (see 'fau help backup')"
	backup_name_check "$1"
	backup_with_toplevel _backup_repair_do "$1"
	local device; device=$(root_device)
	local uuid; uuid=$(blkid -s UUID -o value "$device") || die "blkid couldn't read $device's UUID"
	backup_regen_grub "$device" "$uuid"
	log "repaired: @ now holds '$1'"
	log "this session is still running on the same mount as before (subvolid-pinned, unaffected by the rename, same as backup-restore) -- reboot to pick up the repaired default entry"
}

cmd=${1:-}; [ $# -ge 1 ] && shift

case "$cmd" in
	backup) cmd_backup "$@" ;;
	backup-list) cmd_backup_list "$@" ;;
	backup-remove) cmd_backup_remove "$@" ;;
	backup-restore) cmd_backup_restore "$@" ;;
	backup-repair) cmd_backup_repair "$@" ;;
	*) die "fau-backup: unknown command: $cmd" ;;
esac
