#!/usr/bin/env bash
# fau-bootstrap -- build-time only: installs system package(s) into FAU_ROOT. See fau.md.
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"
# shellcheck source=lib/manifest.sh
source "$SELF_DIR/lib/manifest.sh"
# shellcheck source=lib/repo.sh
source "$SELF_DIR/lib/repo.sh"
# shellcheck source=lib/alpm.sh
source "$SELF_DIR/lib/alpm.sh"
# shellcheck source=lib/build.sh
source "$SELF_DIR/lib/build.sh"
# shellcheck source=lib/recipes.sh
source "$SELF_DIR/lib/recipes.sh"

install_one() {
	local name=$1 want_version=${2:-} chain=${3:-}
	case ":$chain:" in
		*":$name:"*) die "circular dependency: $chain:$name" ;;
	esac
	local file; file=$(repo_lookup_file "$name")
	if [ -z "$file" ]; then
		if alpm_fallback_available; then
			[ -z "$want_version" ] || log "warning: $name isn't in the fau repo -- falling back to the alpm fallback, exact version $want_version can't be guaranteed"
			install_one_alpm "$name"
			return
		fi
		die "package not found in repo: $name (and no pacman mirrorlist/repo-list available to fall back to)"
	fi

	if [ -n "$want_version" ]; then
		local repo_version; repo_version=$(json_get_version "$(repo_json)" "$name")
		[ "$repo_version" = "$want_version" ] || \
			die "manifest wants $name $want_version, but the repo only has $repo_version -- rebuild/repo-add the exact pinned version first"
	fi

	local existing; existing=$(system_get_version "$name")
	local archive="${FAU_REPO_DIR%/}/${file}"

	local depends; depends=$(repo_lookup_depends "$archive")
	if [ -n "${depends:-}" ]; then
		# tr, not `local IFS=','`: IFS is function-scoped and would corrupt system_set's word-splitting (see fau.md).
		for dep in $(printf '%s' "$depends" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			local dep_name dep_op dep_ver
			IFS=$'\t' read -r dep_name dep_op dep_ver <<< "$(dep_parse "$dep")"
			local dep_installed; dep_installed=$(system_get_version "$dep_name")
			if [ -z "$dep_installed" ]; then
				install_one "$dep_name" "" "$chain:$name"
			elif ! version_satisfies "$dep_installed" "$dep_op" "$dep_ver"; then
				log "note: $dep_name $dep_installed is installed but $name needs $dep_name $dep_op$dep_ver -- reinstalling from the repo"
				install_one "$dep_name" "" "$chain:$name"
				dep_installed=$(system_get_version "$dep_name")
				version_satisfies "$dep_installed" "$dep_op" "$dep_ver" || \
					die "$name needs $dep_name $dep_op$dep_ver, but the repo only has $dep_installed"
			fi
		done
	fi

	log "installing $name..."
	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work"
	local version; version=$(pkginfo_field "$work/pkginfo" version)
	mkdir -p "$FAU_ROOT"
	# -aK --checksum: see fau.md's "Installing" section for why both flags are required, not optional.
	record_files "$name" "$work/files"
	rsync -aK --checksum "$work/files/" "$FAU_ROOT/"
	rm -rf "$work"

	system_set "$name" "$version"
	if [ -n "$existing" ]; then
		log "upgraded $name $existing -> $version"
	else
		log "installed $name $version"
	fi
}

cmd_bootstrap() {
	[ $# -ge 1 ] || die "bootstrap requires at least one package name"
	state_init
	local total=$# i=0
	for name in "$@"; do
		i=$((i + 1))
		[ "$total" -eq 1 ] || log "=== [$i/$total] requested package: $name ==="
		install_one "$name"
	done
}

# Builds a base-system package from source, on this live system, from a
# system recipe (fau-recipes' system/ namespace) -- the system-side
# counterpart to `fau build`, merging into FAU_ROOT + system.json instead
# of an isolated app dir. See fau.md.
cmd_bootstrap_build() {
	[ $# -eq 1 ] || die "usage: fau bootstrap-build <name>[=<version>]"
	local arg=$1 name version_req=""
	case "$arg" in
		*=*) name=${arg%%=*}; version_req=${arg#*=} ;;
		*) name=$arg ;;
	esac

	system_recipes_sync || true
	local recipe; recipe=$(system_recipe_lookup "$name") \
		|| die "no system recipe for '$name' (looked in $FAU_SYSTEM_RECIPES_REMOTE_DIR), see 'fau bootstrap-build-list'"

	local PKG_SRC_URL="" PKG_SRC_SHA256="" PKG_VERSION="" PKG_DESCRIPTION=""
	local PKG_DEPENDS="" PKG_BUILD_DEPS=""
	# shellcheck source=/dev/null
	source "$recipe"
	[ -n "$PKG_SRC_URL" ] && [ -n "$PKG_SRC_SHA256" ] && [ -n "$PKG_VERSION" ] \
		|| die "$recipe: PKG_SRC_URL/PKG_SRC_SHA256/PKG_VERSION must all be set"
	declare -F recipe_build >/dev/null || die "$recipe: doesn't define recipe_build"

	# A version other than the recipe's own pinned default needs the recipe's
	# opt-in cooperation, same contract as `fau build name=version`. See fau.md.
	if [ -n "$version_req" ] && [ "$version_req" != "$PKG_VERSION" ]; then
		declare -F recipe_source_for_version >/dev/null \
			|| die "$recipe: doesn't support installing a specific version (no recipe_source_for_version defined), only $PKG_VERSION is available"
		local src_info; src_info=$(recipe_source_for_version "$version_req") \
			|| die "$recipe: recipe_source_for_version failed for version $version_req"
		PKG_SRC_URL=$(printf '%s\n' "$src_info" | sed -n '1p')
		PKG_SRC_SHA256=$(printf '%s\n' "$src_info" | sed -n '2p')
		[ -n "$PKG_SRC_URL" ] || die "$recipe: recipe_source_for_version didn't return a URL for version $version_req"
		PKG_VERSION=$version_req
	fi

	state_init
	local existing; existing=$(system_get_version "$name")

	# PKG_DEPENDS here means "must already be part of the running system" --
	# unlike fau-build's app-dir case, a system package shares the real
	# FAU_ROOT with everything else already installed, nothing to merge in.
	if [ -n "${PKG_DEPENDS:-}" ]; then
		for dep in $(printf '%s' "$PKG_DEPENDS" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			local dep_name dep_op dep_ver
			IFS=$'\t' read -r dep_name dep_op dep_ver <<< "$(dep_parse "$dep")"
			local dep_installed; dep_installed=$(system_get_version "$dep_name")
			[ -n "$dep_installed" ] || die "$name needs $dep_name, but it isn't installed on this system"
			[ -z "$dep_op" ] || version_satisfies "$dep_installed" "$dep_op" "$dep_ver" \
				|| die "$name needs $dep_name $dep_op$dep_ver, but $dep_installed is installed"
		done
	fi

	local -a build_depends=()
	for dep in $(printf '%s' "${PKG_BUILD_DEPS:-}" | tr ',' ' '); do
		dep=$(echo "$dep" | xargs)
		[ -n "$dep" ] && build_depends+=("$dep")
	done

	# Deliberately NOT `local` -- the EXIT trap can fire after this function
	# returns (see fau-build/fau.md for the real bug this fixes).
	sandbox_dir=$(mktemp -d)
	trap 'rm -rf "$sandbox_dir"' EXIT

	if [ "${#build_depends[@]}" -gt 0 ]; then
		log "$name: fetching ${#build_depends[@]} build-only dependenc(y/ies) into a throwaway sandbox"
		alpm_sandbox_fetch "$sandbox_dir" "${build_depends[@]}"
	fi

	log "$name: fetching source ($PKG_SRC_URL)"
	local tarball; tarball=$(build_fetch_source "$PKG_SRC_URL" "$PKG_SRC_SHA256")

	local src; src=$(
		PATH="$sandbox_dir/usr/bin:$PATH" \
		LD_LIBRARY_PATH="$sandbox_dir/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
		PKG_CONFIG_PATH="$sandbox_dir/usr/lib/pkgconfig:$sandbox_dir/usr/share/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}" \
		build_extract_source "$name" "$tarball"
	)

	local files; files=$(mktemp -d)
	log "$name: building $PKG_VERSION (sandbox: $sandbox_dir)"
	PATH="$sandbox_dir/usr/bin:$PATH" \
		LD_LIBRARY_PATH="$sandbox_dir/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
		PKG_CONFIG_PATH="$sandbox_dir/usr/lib/pkgconfig:$sandbox_dir/usr/share/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}" \
		recipe_build "$src" "$files" "$sandbox_dir"

	strip_unreachable_docs "$files"
	strip_unusable_tmpfiles "$files"
	mkdir -p "$FAU_ROOT"
	record_files "$name" "$files"
	rsync -aK --checksum "$files/" "$FAU_ROOT/"
	rm -rf "$files"

	system_set "$name" "$PKG_VERSION"
	if [ -n "$existing" ]; then
		log "rebuilt $name $existing -> $PKG_VERSION from source, merged into $FAU_ROOT"
	else
		log "built and installed $name $PKG_VERSION into $FAU_ROOT"
	fi
}

cmd_bootstrap_build_list() {
	[ $# -eq 0 ] || die "bootstrap-build-list takes no arguments"
	system_recipes_sync || true
	system_recipe_list_names
}

remove_one_file() {
	# Prints 1 if deleted, 0 if skipped (still owned by another package) -- see fau.md.
	local name=$1 relpath=$2 other shared=0
	for other in "$FAU_FILES_DIR"/*; do
		[ -f "$other" ] || continue
		[ "$(basename "$other")" = "$name" ] && continue
		grep -qxF "$relpath" "$other" 2>/dev/null && { shared=1; break; }
	done
	if [ "$shared" -eq 1 ]; then
		echo 0
	else
		rm -f "${FAU_ROOT%/}/$relpath"
		echo 1
	fi
}

cmd_bootstrap_remove() {
	[ $# -ge 1 ] || die "bootstrap-remove requires at least one package name"
	state_init
	for name in "$@"; do
		[ -n "$(system_get_version "$name")" ] || { log "$name is not installed, skipping"; continue; }
		local file_list="$FAU_FILES_DIR/$name"
		if [ -f "$file_list" ]; then
			local relpath removed=0 kept=0 did
			while IFS= read -r relpath; do
				[ -z "$relpath" ] && continue
				did=$(remove_one_file "$name" "$relpath")
				if [ "$did" -eq 1 ]; then removed=$((removed + 1)); else kept=$((kept + 1)); fi
			done < "$file_list"
			rm -f "$file_list"
			system_unset "$name"
			if [ "$kept" -gt 0 ]; then
				log "removed $name ($removed files deleted, $kept left in place -- still owned by another installed package)"
			else
				log "removed $name ($removed files deleted)"
			fi
		else
			# Installed before fau tracked per-package file lists, or a
			# transitive alpm dependency that was never independently
			# tracked in system.json to begin with (see install_one_alpm) --
			# nothing to delete from, so just untrack it like before.
			system_unset "$name"
			log "removed $name from system.json (no file manifest recorded for it -- files left in place)"
		fi
	done
}

cmd_bootstrap_list() {
	state_init
	for n in $(system_list_names); do
		printf '%s %s\n' "$n" "$(system_get_version "$n")"
	done
}

cmd_bootstrap_export() {
	state_init
	if [ $# -ge 1 ]; then cp "$FAU_SYSTEM_JSON" "$1"; else cat "$FAU_SYSTEM_JSON"; fi
}

cmd_bootstrap_apply() {
	[ $# -le 1 ] || die "bootstrap-apply takes at most one manifest file"
	local manifest=${1:-system.json}
	[ -f "$manifest" ] || die "no such file: $manifest"
	state_init
	local n
	for n in $(json_list_names "$manifest"); do
		install_one "$n" "$(json_get_version "$manifest" "$n")"
	done
}

cmd=${1:-}; [ $# -ge 1 ] && shift

case "$cmd" in
	bootstrap) cmd_bootstrap "$@" ;;
	bootstrap-remove) cmd_bootstrap_remove "$@" ;;
	bootstrap-list) cmd_bootstrap_list "$@" ;;
	bootstrap-export) cmd_bootstrap_export "$@" ;;
	bootstrap-apply) cmd_bootstrap_apply "$@" ;;
	bootstrap-build) cmd_bootstrap_build "$@" ;;
	bootstrap-build-list) cmd_bootstrap_build_list "$@" ;;
	*) die "fau-bootstrap: unknown command: $cmd" ;;
esac
