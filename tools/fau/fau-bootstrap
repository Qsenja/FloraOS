#!/usr/bin/env bash
# fau-bootstrap -- build-time only (used by scripts/build-rootfs.sh, not
# meant for end users): installs system package(s) straight into FAU_ROOT
# (/usr, /etc, ...), with dependencies. This is how build-rootfs.sh
# constructs the base rootfs itself (kernel, glibc, coreutils, etc.).
# Called by the `fau` dispatcher; also fully runnable standalone (this is
# exactly what build-rootfs.sh itself does, invoking this tool's own source
# path directly rather than through an installed `fau`).
set -euo pipefail

# readlink -f before dirname: see tools/fau/fau's own comment on this --
# only that file is symlinked today (/usr/bin/fau), but the fix is free.
SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"
# shellcheck source=lib/manifest.sh
source "$SELF_DIR/lib/manifest.sh"
# shellcheck source=lib/repo.sh
source "$SELF_DIR/lib/repo.sh"
# shellcheck source=lib/alpm.sh
source "$SELF_DIR/lib/alpm.sh"

install_one() {
	# install_one <name> [want-version] [ancestor-chain] -- want-version,
	# when given (used by cmd_bootstrap_apply), is enforced against the fau
	# repo's own recorded version: reproducibility from a system.json
	# manifest is only real if a version mismatch is a hard error, not a
	# silent "install whatever's there now". ancestor-chain is the colon-delimited list of
	# packages currently being installed up the call stack -- passed as a
	# plain argument (not a global) so each recursive branch gets its own
	# copy with nothing to clean up on return, and detects a circular
	# depends= (A -> B -> A) as a clear error instead of recursing until
	# bash gives up.
	local name=$1 want_version=${2:-} chain=${3:-}
	case ":$chain:" in
		*":$name:"*) die "circular dependency: $chain:$name" ;;
	esac
	local file; file=$(repo_lookup_file "$name")
	if [ -z "$file" ]; then
		if alpm_fallback_available; then
			[ -z "$want_version" ] || log "warning: $name isn't in the fau repo -- falling back to the alpm fallback, exact version $want_version can't be guaranteed"
			install_one_alpm "$name"
			return
		fi
		die "package not found in repo: $name (and no pacman mirrorlist/repo-list available to fall back to)"
	fi

	if [ -n "$want_version" ]; then
		local repo_version; repo_version=$(json_get_version "$(repo_json)" "$name")
		[ "$repo_version" = "$want_version" ] || \
			die "manifest wants $name $want_version, but the repo only has $repo_version -- rebuild/repo-add the exact pinned version first"
	fi

	local existing; existing=$(system_get_version "$name")
	local archive="${FAU_REPO_DIR%/}/${file}"

	local depends; depends=$(repo_lookup_depends "$archive")
	if [ -n "${depends:-}" ]; then
		# tr, not `local IFS=','`: IFS is function-scoped, not block-scoped,
		# so it would still be ',' for every command below this loop within
		# this same call (notably system_set's own word-splitting) -- that's
		# exactly what corrupted system.json before this fix.
		for dep in $(printf '%s' "$depends" | tr ',' ' '); do
			dep=$(echo "$dep" | xargs)
			[ -z "$dep" ] && continue
			local dep_name dep_op dep_ver
			IFS=$'\t' read -r dep_name dep_op dep_ver <<< "$(dep_parse "$dep")"
			local dep_installed; dep_installed=$(system_get_version "$dep_name")
			if [ -z "$dep_installed" ]; then
				install_one "$dep_name" "" "$chain:$name"
			elif ! version_satisfies "$dep_installed" "$dep_op" "$dep_ver"; then
				log "note: $dep_name $dep_installed is installed but $name needs $dep_name $dep_op$dep_ver -- reinstalling from the repo"
				install_one "$dep_name" "" "$chain:$name"
				dep_installed=$(system_get_version "$dep_name")
				version_satisfies "$dep_installed" "$dep_op" "$dep_ver" || \
					die "$name needs $dep_name $dep_op$dep_ver, but the repo only has $dep_installed"
			fi
		done
	fi

	log "installing $name..."
	local work; work=$(mktemp -d)
	tar -I zstd -xf "$archive" -C "$work"
	local version; version=$(pkginfo_field "$work/pkginfo" version)
	mkdir -p "$FAU_ROOT"
	# rsync -a alone replaces a destination symlink-to-directory (e.g. the
	# merged-/usr bin/sbin/lib/lib64 symlinks) with a real directory;
	# --keep-dirlinks (-K) keeps the symlink and merges into its target
	# instead, which is what installing multiple packages into one merged
	# root requires. Plain cp -a refuses the merge outright ("cannot
	# overwrite non-directory X with directory Y").
	# --checksum: without it, rsync's default quick-check (same size + same
	# mtime => skip) silently keeps the OLD file content on an upgrade
	# whenever two versions of a file happen to match in both -- reproduced
	# directly (a package bumped from 1.0 to 2.0 with same-size files kept
	# serving the 1.0 binary after "upgrading" to 2.0, with system.json
	# claiming 2.0 the whole time). Package archives aren't gigabytes, so
	# hashing every file on install is the correct trade, not a slow one.
	record_files "$name" "$work/files"
	rsync -aK --checksum "$work/files/" "$FAU_ROOT/"
	rm -rf "$work"

	system_set "$name" "$version"
	if [ -n "$existing" ]; then
		log "upgraded $name $existing -> $version"
	else
		log "installed $name $version"
	fi
}

cmd_bootstrap() {
	[ $# -ge 1 ] || die "bootstrap requires at least one package name"
	state_init
	local total=$# i=0
	for name in "$@"; do
		i=$((i + 1))
		[ "$total" -eq 1 ] || log "=== [$i/$total] requested package: $name ==="
		install_one "$name"
	done
}

remove_one_file() {
	# remove_one_file <name> <relpath> -- deletes relpath from FAU_ROOT
	# unless some OTHER still-installed package's own file list also
	# claims it (rsync merges every package into one shared FAU_ROOT, so
	# paths legitimately do overlap between packages -- e.g. two things
	# both shipping the same merged-/usr dir). Prints 1 on its stdout if
	# it actually deleted the file, 0 if it skipped a shared one, so the
	# caller can tally without a namerefs/global counter.
	local name=$1 relpath=$2 other shared=0
	for other in "$FAU_FILES_DIR"/*; do
		[ -f "$other" ] || continue
		[ "$(basename "$other")" = "$name" ] && continue
		grep -qxF "$relpath" "$other" 2>/dev/null && { shared=1; break; }
	done
	if [ "$shared" -eq 1 ]; then
		echo 0
	else
		rm -f "${FAU_ROOT%/}/$relpath"
		echo 1
	fi
}

cmd_bootstrap_remove() {
	[ $# -ge 1 ] || die "bootstrap-remove requires at least one package name"
	state_init
	for name in "$@"; do
		[ -n "$(system_get_version "$name")" ] || { log "$name is not installed, skipping"; continue; }
		local file_list="$FAU_FILES_DIR/$name"
		if [ -f "$file_list" ]; then
			local relpath removed=0 kept=0 did
			while IFS= read -r relpath; do
				[ -z "$relpath" ] && continue
				did=$(remove_one_file "$name" "$relpath")
				if [ "$did" -eq 1 ]; then removed=$((removed + 1)); else kept=$((kept + 1)); fi
			done < "$file_list"
			rm -f "$file_list"
			system_unset "$name"
			if [ "$kept" -gt 0 ]; then
				log "removed $name ($removed files deleted, $kept left in place -- still owned by another installed package)"
			else
				log "removed $name ($removed files deleted)"
			fi
		else
			# Installed before fau tracked per-package file lists, or a
			# transitive alpm dependency that was never independently
			# tracked in system.json to begin with (see install_one_alpm) --
			# nothing to delete from, so just untrack it like before.
			system_unset "$name"
			log "removed $name from system.json (no file manifest recorded for it -- files left in place)"
		fi
	done
}

cmd_bootstrap_list() {
	state_init
	for n in $(system_list_names); do
		printf '%s %s\n' "$n" "$(system_get_version "$n")"
	done
}

cmd_bootstrap_export() {
	state_init
	if [ $# -ge 1 ]; then cp "$FAU_SYSTEM_JSON" "$1"; else cat "$FAU_SYSTEM_JSON"; fi
}

cmd_bootstrap_apply() {
	[ $# -le 1 ] || die "bootstrap-apply takes at most one manifest file"
	local manifest=${1:-system.json}
	[ -f "$manifest" ] || die "no such file: $manifest"
	state_init
	# json_list_names/json_get_version already parse this exact
	# {"packages":{"name":{"version":"x"}}} shape (system.json's own format)
	# -- reusing them instead of a second hand-rolled regex is also what
	# surfaced this function used to read names only and silently drop the
	# version, so "bootstrap-apply" never actually verified it installed
	# what the manifest recorded.
	local n
	for n in $(json_list_names "$manifest"); do
		install_one "$n" "$(json_get_version "$manifest" "$n")"
	done
}

cmd=${1:-}; [ $# -ge 1 ] && shift

case "$cmd" in
	bootstrap) cmd_bootstrap "$@" ;;
	bootstrap-remove) cmd_bootstrap_remove "$@" ;;
	bootstrap-list) cmd_bootstrap_list "$@" ;;
	bootstrap-export) cmd_bootstrap_export "$@" ;;
	bootstrap-apply) cmd_bootstrap_apply "$@" ;;
	*) die "fau-bootstrap: unknown command: $cmd" ;;
esac
