#!/usr/bin/env bash
# fau-repo -- fau's own local package repo (repo-add/repo-index). See fau.md.
set -euo pipefail

SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=lib/common.sh
source "$SELF_DIR/lib/common.sh"
# shellcheck source=lib/repo.sh
source "$SELF_DIR/lib/repo.sh"

cmd=${1:-}; [ $# -ge 1 ] && shift

case "$cmd" in
	repo-add)
		[ $# -eq 1 ] || die "usage: fau repo-add <archive>"
		repo_add "$1"
		;;
	repo-index)
		[ $# -eq 0 ] || die "repo-index takes no arguments"
		repo_index
		;;
	*) die "fau-repo: unknown command: $cmd" ;;
esac
