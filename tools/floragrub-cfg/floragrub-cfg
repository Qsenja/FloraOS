#!/usr/bin/env bash
# floragrub-cfg -- generates FloraOS's /boot/grub/grub.cfg. See floragrub-cfg.md.
set -euo pipefail

die() { echo "floragrub-cfg: error: $*" >&2; exit 1; }

[ $# -eq 3 ] || die "usage: floragrub-cfg <root-partition-device> <root-uuid> <output-grub-cfg-path>"
device=$1
uuid=$2
out=$3

[ -b "$device" ] || die "$device is not a block device"

tmp=$(mktemp -d -p /dev/shm) # /dev/shm, not /tmp -- see floragrub-cfg.md
cleanup() { umount "$tmp" 2>/dev/null || true; rmdir "$tmp" 2>/dev/null || true; }
trap cleanup EXIT
mount -o subvolid=5 "$device" "$tmp" || die "mount -o subvolid=5 $device failed"

names=()
if [ -d "$tmp/@snapshots" ]; then
	while IFS= read -r name; do
		[ -n "$name" ] && names+=("$name")
	done < <(cd "$tmp/@snapshots" && ls -1t --)
fi

write_entry() {
	local title=$1 subvol=$2
	printf 'menuentry "%s" {\n' "$title"
	printf '\tlinux /%s/boot/vmlinuz-floraos root=%s rootflags=subvol=%s rootfstype=btrfs ro console=tty0 console=ttyS0\n' \
		"$subvol" "$device" "$subvol"
	printf '}\n'
}

{
	printf 'set default=0\n'
	printf 'set timeout=3\n'
	printf 'insmod part_msdos\n'
	printf 'insmod btrfs\n'
	# grub-reboot needs this load_env/next_entry handling, see floragrub-cfg.md
	printf 'if [ -s $prefix/grubenv ]; then\n'
	printf '\tload_env\n'
	printf 'fi\n'
	printf 'if [ "${next_entry}" ]; then\n'
	printf '\tset default="${next_entry}"\n'
	printf '\tset next_entry=\n'
	printf '\tsave_env next_entry\n'
	printf 'fi\n'
	printf 'search --no-floppy --fs-uuid --set=root %s\n' "$uuid"
	write_entry "FloraOS" "@"
	for name in "${names[@]}"; do
		write_entry "FloraOS (backup: $name)" "@snapshots/$name"
	done
} > "$out"
