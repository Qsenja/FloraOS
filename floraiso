#!/usr/bin/env bash
# floraiso — build and test the FloraOS ISO. Zero-config: `./floraiso build`
# builds the rootfs (if needed) and the ISO in one command using the
# defaults in config/floraos.conf.
set -euo pipefail

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
	cat <<'EOF'
usage: floraiso <command>

commands:
  build     build the rootfs (if needed) and the ISO -- config/floraos.conf
  rootfs    build only the rootfs (work/rootfs), skip the ISO step
  test      boot the built ISO in QEMU (see scripts/test-iso.sh) -- the
              quick sanity check, not the full suite below
  test-all  run every scripts/test-*.sh test in sequence with a summary
              (see scripts/test-all.sh --help for --all/--only/--list)
EOF
}

[ $# -ge 1 ] || { usage; exit 1; }
case "$1" in
	build) exec "$SELF_DIR/scripts/build-iso.sh" ;;
	rootfs) exec "$SELF_DIR/scripts/build-rootfs.sh" ;;
	test) shift; exec "$SELF_DIR/scripts/test-iso.sh" "$@" ;;
	test-all) shift; exec "$SELF_DIR/scripts/test-all.sh" "$@" ;;
	-h|--help|help) usage ;;
	*) echo "floraiso: unknown command: $1" >&2; usage; exit 1 ;;
esac
